---
import BaseLayout from '../../layouts/BaseLayout.astro'
import { toHTML } from '@portabletext/to-html'
import { client, urlFor, sanityImgSrcset } from '../../lib/sanity'
import { ALL_TRIPS_QUERY } from '../../lib/queries'

const ptComponents = {
  marks: {
    underline:       ({ children }: any) => `<span class="pt-u">${children}</span>`,
    'strike-through':({ children }: any) => `<s>${children}</s>`,
    link: ({ children, value }: any) => {
      const href = value?.href ?? '#'
      const external = /^https?:\/\//i.test(href)
      return `<a href="${href}"${external ? ' target="_blank" rel="noopener noreferrer"' : ''}>${children}</a>`
    },
  },
}

export async function getStaticPaths() {
  const trips = await client.fetch(ALL_TRIPS_QUERY)
  return trips.map((trip: any) => ({
    params: { id: trip.id },
    props:  { trip, trips },
  }))
}

const { trip, trips: allTrips } = Astro.props

const HeroTitleTag = trip.storyTitle ? 'p' : 'h1'

const tripIndex   = allTrips.findIndex((t: any) => t.id === trip.id)
const nextIndex   = (tripIndex + 1) % allTrips.length
const nextTrip    = allTrips[nextIndex]

// Hero image URLs
const heroUrl    = trip.heroImage
  ? urlFor(trip.heroImage).width(1600).quality(90).format('webp').url()
  : ''
const heroSrcset = trip.heroImage
  ? sanityImgSrcset(trip.heroImage, [800, 1200, 1600, 2400], 90)
  : ''
const ogUrl = trip.heroImage
  ? urlFor(trip.heroImage).width(1200).quality(85).format('webp').url()
  : ''
const ogImageWidth  = trip.heroImage?.dims ? 1200 : undefined
const ogImageHeight = trip.heroImage?.dims
  ? Math.round(1200 / trip.heroImage.dims.width * trip.heroImage.dims.height)
  : undefined

// JSON-LD structured data — derive from the configured site so it never drifts
const siteUrl   = (Astro.site?.href ?? 'https://ourroamingreels.com/').replace(/\/$/, '')
const pageUrl   = `${siteUrl}/expedition/${trip.id}`
const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type':         'Article',
      headline:        trip.storyTitle || trip.pageTitle.join(' '),
      description:     trip.description,
      image:           ogUrl,
      datePublished:   trip.tripDate,
      url:             pageUrl,
      author:    { '@type': 'Organization', name: 'Our Roaming Reels' },
      publisher: {
        '@type': 'Organization',
        name:    'Our Roaming Reels — A Field Journal',
        url:     siteUrl,
      },
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home',        item: `${siteUrl}/`            },
        { '@type': 'ListItem', position: 2, name: 'Expeditions', item: `${siteUrl}/expeditions` },
        { '@type': 'ListItem', position: 3, name: trip.pageTitle.join(' '), item: pageUrl },
      ],
    },
  ],
})

// Next expedition
const nextUrl     = nextTrip?.heroImage
  ? urlFor(nextTrip.heroImage).width(800).quality(85).format('webp').url()
  : ''
const nextSrcset  = nextTrip?.heroImage
  ? sanityImgSrcset(nextTrip.heroImage, [500, 800, 1200])
  : ''
const nextHeroUrl = nextTrip?.heroImage
  ? urlFor(nextTrip.heroImage).width(1600).quality(90).format('webp').url()
  : ''
// Same srcset shape the destination trip-hero-img uses — so the browser's
// preload picks the exact resolution it'd pick on first paint, no wasted
// fetch and no cache miss when the user clicks the next-trip card.
const nextHeroSrcset = nextTrip?.heroImage
  ? sanityImgSrcset(nextTrip.heroImage, [800, 1200, 1600, 2400], 90)
  : ''

// ── Elevation profile helpers ────────────────────────────────────────────────
async function parseGpxElevation(gpxUrl: string): Promise<number[]> {
  try {
    const xml  = await fetch(gpxUrl).then(r => r.text())
    const eles = [...xml.matchAll(/<ele>([\d.]+)<\/ele>/g)].map(m => parseFloat(m[1]))
    if (eles.length === 0) return []
    const step = Math.max(1, Math.floor(eles.length / 20))
    return eles.filter((_, i) => i % step === 0).slice(0, 20)
  } catch {
    return []
  }
}

function placeholderElevation(seed: string, points = 14, base = 1000): number[] {
  let h = [...seed].reduce((a, c) => (Math.imul(31, a) + c.charCodeAt(0)) | 0, 0)
  const rand = () => {
    h = (Math.imul(h ^ (h >>> 16), 0x45d9f3b)) | 0
    return (h >>> 0) / 0xffffffff
  }
  // Vary base elevation ±35% per trip so each profile looks distinct
  const tripBase = Math.round(base * (0.65 + rand() * 0.7))
  // Step size controls how "jagged" the profile is — varies 8-22% of base
  const stepFactor = 0.08 + rand() * 0.14
  let elev = tripBase
  return Array.from({ length: points }, () => {
    elev += (rand() * 2 - 1) * tripBase * stepFactor
    return Math.round(Math.max(100, Math.min(tripBase * 2.5, elev)))
  })
}

// Seeded-random placeholder route — generates a unique bezier path per trip.
// All trips without a GPX file get a visually distinct route that still shares
// the same general left→right, lower→higher mountainous shape.
function placeholderRoute(
  seed: string,
  w: number, h: number, pad: number
): { path: string; startPt: {x:number;y:number}; endPt: {x:number;y:number}; midPts: {x:number;y:number}[] } {
  let hash = [...seed].reduce((a, c) => (Math.imul(31, a) + c.charCodeAt(0)) | 0, 0)
  const rand = () => {
    hash = (Math.imul(hash ^ (hash >>> 16), 0x45d9f3b)) | 0
    return (hash >>> 0) / 0xffffffff
  }

  const usW = w - 2 * pad
  const usH = h - 2 * pad

  // Jitter a base value by ±pct (5-10% per the user's request)
  const jit = (v: number, pct = 0.08) => v + (rand() - 0.5) * 2 * v * pct

  // Base control points from the original hardcoded path
  const start  = { x: jit(100), y: jit(420) }
  const cp1    = { x: jit(160), y: jit(400) }
  const cp2    = { x: jit(200), y: jit(350) }
  const a1     = { x: jit(265), y: jit(324) }
  const s1     = { x: jit(370), y: jit(296) }
  const a2     = { x: jit(430), y: jit(304) }
  const s2     = { x: jit(550), y: jit(288) }
  const a3     = { x: jit(610), y: jit(264) }
  const s3     = { x: jit(710), y: jit(240) }
  const end    = { x: jit(750), y: jit(250) }

  // Intermediate waypoint dots
  const mid1   = { x: jit(380), y: jit(300) }
  const mid2   = { x: jit(615), y: jit(268) }

  const path =
    `M ${start.x.toFixed(1)},${start.y.toFixed(1)} ` +
    `C ${cp1.x.toFixed(1)},${cp1.y.toFixed(1)} ${cp2.x.toFixed(1)},${cp2.y.toFixed(1)} ${a1.x.toFixed(1)},${a1.y.toFixed(1)} ` +
    `S ${s1.x.toFixed(1)},${s1.y.toFixed(1)} ${a2.x.toFixed(1)},${a2.y.toFixed(1)} ` +
    `S ${s2.x.toFixed(1)},${s2.y.toFixed(1)} ${a3.x.toFixed(1)},${a3.y.toFixed(1)} ` +
    `S ${s3.x.toFixed(1)},${s3.y.toFixed(1)} ${end.x.toFixed(1)},${end.y.toFixed(1)}`

  return { path, startPt: start, endPt: end, midPts: [mid1, mid2] }
}

let elevPoints: number[] = []
if (trip.routeGpxUrl) {
  elevPoints = await parseGpxElevation(trip.routeGpxUrl)
}
if (elevPoints.length < 2 && trip.elevationPoints?.length >= 2) {
  elevPoints = trip.elevationPoints
}
if (elevPoints.length < 2) {
  elevPoints = placeholderElevation(trip.id)
}

const elMin   = Math.min(...elevPoints)
const elMax   = Math.max(...elevPoints)
const elRange = elMax - elMin || 1
const svgXPad = 4
const svgXW   = 28
const svgYPad = 8
const svgYH   = 144

const svgPoints = elevPoints.map((e, i) => {
  const x = svgXPad + ((e - elMin) / elRange) * svgXW
  const y = svgYPad + (i / (elevPoints.length - 1)) * svgYH
  return { x: parseFloat(x.toFixed(1)), y: parseFloat(y.toFixed(1)) }
})
const pointsStr  = svgPoints.map(p => `${p.x},${p.y}`).join(' ')
const fillPoints = pointsStr + ` ${svgXPad},${svgYPad + svgYH} ${svgXPad},${svgYPad}`
const firstX = svgPoints[0].x
const firstY = svgPoints[0].y

// ── Horizontal elevation strip (mobile bottom bar) ───────────────────────────
// X-axis = reading progress (left → right), Y-axis = elevation (top = high)
const stripW = 400, stripH = 40
const stripXPad = 8, stripYPad = 5
const stripXUsable = stripW - 2 * stripXPad
const stripYUsable = stripH - 2 * stripYPad

const svgStripPoints = elevPoints.map((e, i) => ({
  x: parseFloat((stripXPad + (i / (elevPoints.length - 1)) * stripXUsable).toFixed(1)),
  y: parseFloat((stripYPad + (1 - (e - elMin) / elRange) * stripYUsable).toFixed(1)),
}))
const stripPointsStr  = svgStripPoints.map(p => `${p.x},${p.y}`).join(' ')
const stripFillPoints = stripPointsStr + ` ${stripXPad + stripXUsable},${stripH - stripYPad} ${stripXPad},${stripH - stripYPad}`
const stripFirstX = svgStripPoints[0].x
const stripFirstY = svgStripPoints[0].y

// ── Route map SVG (from GPX lat/lon or placeholder) ──────────────────────────
async function parseGpxRoute(gpxUrl: string): Promise<{lat: number; lon: number}[]> {
  try {
    const xml = await fetch(gpxUrl).then(r => r.text())
    const matches = [...xml.matchAll(/<trkpt[^>]+lat="([\d.-]+)"[^>]+lon="([\d.-]+)"/g)]
    if (matches.length === 0) return []
    const step = Math.max(1, Math.floor(matches.length / 40))
    return matches
      .filter((_, i) => i % step === 0)
      .slice(0, 40)
      .map(m => ({ lat: parseFloat(m[1]), lon: parseFloat(m[2]) }))
  } catch {
    return []
  }
}

const mapW = 800, mapH = 520, mapPad = 48
let routeSvgPath  = ''
let routeStartPt: {x: number; y: number} | null = null
let routeEndPt:   {x: number; y: number} | null = null

if (trip.routeGpxUrl) {
  const routePoints = await parseGpxRoute(trip.routeGpxUrl)
  if (routePoints.length >= 2) {
    const lats = routePoints.map(p => p.lat)
    const lons = routePoints.map(p => p.lon)
    const minLat = Math.min(...lats), maxLat = Math.max(...lats)
    const minLon = Math.min(...lons), maxLon = Math.max(...lons)
    const lonRange = maxLon - minLon || 0.001
    const latRange = maxLat - minLat || 0.001
    const usableW  = mapW - 2 * mapPad
    const usableH  = mapH - 2 * mapPad
    const pts = routePoints.map(p => ({
      x: mapPad + ((p.lon - minLon) / lonRange) * usableW,
      y: mapPad + ((maxLat - p.lat) / latRange) * usableH,
    }))
    routeSvgPath = 'M ' + pts.map(p => `${p.x.toFixed(1)},${p.y.toFixed(1)}`).join(' L ')
    routeStartPt = pts[0]
    routeEndPt   = pts[pts.length - 1]
  }
}

// Seeded placeholder route — unique per trip, stable across rebuilds
const phRoute = routeSvgPath ? null : placeholderRoute(trip.id, mapW, mapH, mapPad)

// ── Story pre-processing ─────────────────────────────────────────────────────
// Section blocks (type=dayEntry) come in four flavours:
//   • overview → eyebrow "Overview"
//   • day      → auto-numbered "Day 01", "Day 02" (increments per day section)
//   • final    → eyebrow "Final Thoughts"
//   • custom   → author-supplied eyebrow text
// Existing data without an eyebrowKind defaults to Day mode for backwards compat.
let dayCounter     = 0
let sectionCounter = 0
const storyProcessed: any[] = (trip.story ?? []).map((block: any) => {
  if (block.type === 'dayEntry') {
    sectionCounter++
    const kind = block.eyebrowKind ?? 'day'
    if (kind === 'day') dayCounter++

    const eyebrow =
      kind === 'overview' ? 'Overview' :
      kind === 'final'    ? 'Final Thoughts' :
      kind === 'custom'   ? (block.customEyebrow ?? 'Section') :
                            `Day ${String(dayCounter).padStart(2, '0')}`

    const anchor =
      kind === 'overview' ? 'overview' :
      kind === 'final'    ? 'final-thoughts' :
      kind === 'day'      ? `day-${dayCounter}` :
                            `section-${sectionCounter}`

    // Big rust-coloured number renders only for Day-kind sections so the
    // numbering never gets out of sync with Day 01 / Day 02 (Overview and
    // Final Thoughts would otherwise shift everything off by one).
    const bigNum = kind === 'day' ? String(dayCounter).padStart(2, '0') : null

    return { ...block, _idx: sectionCounter, _eyebrow: eyebrow, _anchor: anchor, _bigNum: bigNum }
  }
  return block
})

const dayEntries = storyProcessed
  .filter(b => b.type === 'dayEntry')
  .map(b => ({
    num:   b._bigNum ?? '',
    title: b.dayTitle ?? b._eyebrow,
    id:    b._anchor,
  }))

const hasFieldIntel = trip.fieldIntel?.length > 0
const hasSidebar    = dayEntries.length > 0

// ── Video embed helper ───────────────────────────────────────────────────────
function getEmbedUrl(url: string): string {
  const yt = url.match(/(?:youtube\.com\/watch\?v=|youtu\.be\/)([a-zA-Z0-9_-]+)/)
  if (yt) return `https://www.youtube.com/embed/${yt[1]}`
  const vimeo = url.match(/vimeo\.com\/(\d+)/)
  if (vimeo) return `https://player.vimeo.com/video/${vimeo[1]}`
  return url
}

// ── Lightbox image list ──────────────────────────────────────────────────────
interface LightboxImage {
  src:     string
  alt:     string
  caption: string
  palette: string
}

const lightboxImages: LightboxImage[] = []
const lbByKey = new Map<string, number>()

for (const block of storyProcessed) {
  if (block.type === 'image' && block.image) {
    lbByKey.set(block._key, lightboxImages.length)
    lightboxImages.push({
      src:     urlFor(block.image).width(1800).quality(90).format('webp').url(),
      alt:     block.image.alt ?? '',
      caption: block.image.caption ?? '',
      palette: block.image.palette?.vibrant?.background ?? '',
    })
  } else if ((block.type === 'gallery' || block.type === 'strip') && block.images?.length) {
    for (const img of block.images) {
      lbByKey.set(img._key, lightboxImages.length)
      lightboxImages.push({
        src:     urlFor(img).width(1800).quality(90).format('webp').url(),
        alt:     img.alt ?? '',
        caption: img.caption ?? '',
        palette: img.palette?.vibrant?.background ?? '',
      })
    }
  }
}
---

<BaseLayout
  title={`${trip.pageTitle.join(' ')} — Our Roaming Reels`}
  description={trip.description}
  ogImage={ogUrl}
  ogImageWidth={ogImageWidth}
  ogImageHeight={ogImageHeight}
  ogType="article"
  isExpedition={true}
  preloadImage={heroUrl}
>
  <Fragment slot="head">
    {/* Preload the next-trip's hero so the iris-to-hero handoff doesn't
        flash the accent-colour background on first visit. imagesrcset +
        imagesizes mirror the destination trip-hero-img so the browser
        picks the exact resolution it'd otherwise pick on render. */}
    {nextTrip && nextHeroUrl && (
      <link
        rel="preload"
        as="image"
        href={nextHeroUrl}
        imagesrcset={nextHeroSrcset}
        imagesizes="100vw"
      />
    )}
    <script type="application/ld+json" set:html={jsonLd} />
  </Fragment>
  <div class="trip-page">

    <!-- Back button -->
    <a href="/expeditions" class="back-btn">
      <span class="back-arrow">←</span>
      <span>All Expeditions</span>
    </a>

    <!-- ── Hero ─────────────────────────────────────────────────────────── -->
    <section class="trip-hero">
      <div class="trip-hero-img-wrap" style={`background-color:${trip.accentColor}`}>
        <img
          class="trip-hero-img"
          src={heroUrl}
          srcset={heroSrcset}
          sizes="100vw"
          alt={trip.heroImage?.alt ?? trip.location}
          loading="eager"
          decoding="sync"
          fetchpriority="high"
        />
        <div class="trip-hero-overlay"></div>
      </div>

      <div class="trip-hero-content">
        <div class="trip-coords">
          <!-- Compass SVG — needle spins in and settles north, JS animates on load -->
          <div class="trip-compass" aria-hidden="true">
            <svg class="compass-svg" viewBox="0 0 44 44" xmlns="http://www.w3.org/2000/svg">
              <circle cx="22" cy="22" r="20" fill="none" stroke="rgba(240,226,206,0.2)" stroke-width="0.6"/>
              <text x="22" y="7" text-anchor="middle" fill="rgba(240,226,206,0.55)" font-family="Space Mono, monospace" font-size="4.5" letter-spacing="0">N</text>
              <text x="22" y="41" text-anchor="middle" fill="rgba(240,226,206,0.28)" font-family="Space Mono, monospace" font-size="4">S</text>
              <text x="6.5" y="23.5" text-anchor="middle" fill="rgba(240,226,206,0.28)" font-family="Space Mono, monospace" font-size="4">W</text>
              <text x="37.5" y="23.5" text-anchor="middle" fill="rgba(240,226,206,0.28)" font-family="Space Mono, monospace" font-size="4">E</text>
              <!-- Tick marks at cardinal points -->
              <line x1="22" y1="3.5" x2="22" y2="7"   stroke="rgba(240,226,206,0.3)" stroke-width="0.5"/>
              <line x1="22" y1="37" x2="22" y2="40.5" stroke="rgba(240,226,206,0.3)" stroke-width="0.5"/>
              <line x1="3.5" y1="22" x2="7"  y2="22"  stroke="rgba(240,226,206,0.3)" stroke-width="0.5"/>
              <line x1="37" y1="22" x2="40.5" y2="22" stroke="rgba(240,226,206,0.3)" stroke-width="0.5"/>
              <!-- North needle — rust -->
              <polygon class="compass-needle-n" points="22,8 24.5,22 19.5,22" fill="var(--rust)" opacity="0.9"/>
              <!-- South needle — muted -->
              <polygon class="compass-needle-s" points="22,36 24.5,22 19.5,22" fill="rgba(160,144,120,0.45)"/>
              <!-- Center pin -->
              <circle cx="22" cy="22" r="2" fill="var(--bone)" opacity="0.5"/>
              <circle cx="22" cy="22" r="0.8" fill="var(--rust)"/>
            </svg>
          </div>
          <span class="trip-dot"></span>
          <span>{trip.coords}</span>
        </div>

        <HeroTitleTag class="trip-title">
          {trip.pageTitle.map((line: string, i: number) => (
            <span class="line" style={i === 1 ? `color:${trip.accentColor}` : ''}>
              {line}
            </span>
          ))}
        </HeroTitleTag>
      </div>

      <!-- Stats bar -->
      <div class="trip-stats-bar">
        <div class="trip-stats-inner">
          <div class="stat">
            <span class="stat-label">Location</span>
            <span class="stat-value">{trip.location}</span>
          </div>
          <div class="stat-divider"></div>
          <div class="stat">
            <span class="stat-label">Date</span>
            <span class="stat-value">{trip.date}</span>
          </div>
          <div class="stat-divider"></div>
          <div class="stat">
            <span class="stat-label">Distance</span>
            <span class="stat-value">{trip.distance}</span>
          </div>
          <div class="stat-divider"></div>
          <div class="stat">
            <span class="stat-label">Elevation</span>
            <span class="stat-value">{trip.elevation}</span>
          </div>
          <div class="stat-divider"></div>
          <div class="stat">
            <span class="stat-label">Duration</span>
            <span class="stat-value">{trip.duration}</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ── Intro + Field Intelligence ───────────────────────────────────── -->
    <div class="trip-wide-wrap">
      <section class={`trip-intro${hasFieldIntel ? '' : ' trip-intro--full'}`}>

        <div class="trip-intro-text story-block">
          <div class="trip-intro-eyebrow">The Expedition</div>
          {trip.storyTitle
            ? <h1 class="trip-intro-heading">{trip.storyTitle}</h1>
            : null
          }
          {trip.description && (
            <p class="trip-intro-body">{trip.description}</p>
          )}

          {trip.conditions?.length > 0 && (
            <div class="trip-conditions">
              <div class="trip-conditions-eyebrow">Conditions at the time</div>
              <div class="trip-conditions-grid">
                {trip.conditions.map((c: any) => (
                  <div class="condition-item">
                    {c.icon && <div class="condition-icon">{c.icon}</div>}
                    <div class="condition-label">{c.label}</div>
                    <div class="condition-value">{c.value}</div>
                    {c.subtext && <div class="condition-sub">{c.subtext}</div>}
                  </div>
                ))}
              </div>
            </div>
          )}
        </div>

        {hasFieldIntel && (
          <aside class="trip-field-intel story-block">
            <div class="field-intel-title">Field Intelligence</div>

            {(trip.fieldIntel ?? []).map((row: any) => (
              <div class="intel-row">
                <span class="intel-key">{row.key}</span>
                <span class={`intel-val${row.status ? ` intel-val--${row.status}` : ''}`}>
                  {row.value}
                </span>
              </div>
            ))}
          </aside>
        )}
      </section>

      <!-- ── Route map ─────────────────────────────────────────────────── -->
      <div class={`trip-map-section story-block${hasSidebar ? '' : ' trip-map-section--no-sidebar'}`}>
        <div class="trip-map-eyebrow">Route</div>
        <div class="trip-map-placeholder">
          <svg
            class="trip-map-svg"
            viewBox={`0 0 ${mapW} ${mapH}`}
            preserveAspectRatio="none"
            xmlns="http://www.w3.org/2000/svg"
            aria-hidden="true"
          >
            {routeSvgPath ? (
              <>
                <!-- GPX-derived route -->
                <path
                  class="map-route-path"
                  d={routeSvgPath}
                  fill="none"
                  stroke="rgba(192,72,32,0.65)"
                  stroke-width="2"
                  stroke-dasharray="6 4"
                  stroke-linecap="round"
                />
                <!-- Progress overlay — JS fills this as the cursor moves -->
                <path
                  class="map-route-progress"
                  d={routeSvgPath}
                  fill="none"
                  stroke="var(--rust)"
                  stroke-width="2.5"
                  stroke-linecap="round"
                />
                {routeStartPt && (
                  <circle class="map-route-dot map-route-dot--start" cx={routeStartPt.x} cy={routeStartPt.y} r="5" fill="var(--rust)" />
                )}
                {routeEndPt && (
                  <circle class="map-route-dot" cx={routeEndPt.x} cy={routeEndPt.y} r="5" fill="none" stroke="var(--rust)" stroke-width="1.5" opacity="0.5" />
                )}
              </>
            ) : (
              <>
                <!-- Seeded topo placeholder — unique per trip via placeholderRoute() -->
                <ellipse class="map-topo-ring" cx="280" cy="280" rx="240" ry="180" fill="none" stroke="rgba(168,191,201,0.06)" stroke-width="1"/>
                <ellipse class="map-topo-ring" cx="280" cy="280" rx="190" ry="140" fill="none" stroke="rgba(168,191,201,0.05)" stroke-width="1"/>
                <ellipse class="map-topo-ring" cx="280" cy="280" rx="140" ry="100" fill="none" stroke="rgba(168,191,201,0.04)" stroke-width="1"/>
                <ellipse class="map-topo-ring" cx="600" cy="260" rx="210" ry="160" fill="none" stroke="rgba(168,191,201,0.06)" stroke-width="1"/>
                <ellipse class="map-topo-ring" cx="600" cy="260" rx="160" ry="120" fill="none" stroke="rgba(168,191,201,0.05)" stroke-width="1"/>
                <path
                  class="map-route-path"
                  d={phRoute!.path}
                  fill="none"
                  stroke="rgba(192,72,32,0.6)"
                  stroke-width="2"
                  stroke-dasharray="6 4"
                  stroke-linecap="round"
                />
                <path
                  class="map-route-progress"
                  d={phRoute!.path}
                  fill="none"
                  stroke="var(--rust)"
                  stroke-width="2.5"
                  stroke-linecap="round"
                />
                <circle class="map-route-dot map-route-dot--start" cx={phRoute!.startPt.x} cy={phRoute!.startPt.y} r="5" fill="var(--rust)" />
                <circle class="map-route-dot" cx={phRoute!.endPt.x} cy={phRoute!.endPt.y} r="5" fill="none" stroke="var(--rust)" stroke-width="1.5" opacity="0.5" />
                <circle class="map-route-dot" cx={phRoute!.midPts[0].x} cy={phRoute!.midPts[0].y} r="3.5" fill="rgba(192,72,32,0.7)" />
                <circle class="map-route-dot" cx={phRoute!.midPts[1].x} cy={phRoute!.midPts[1].y} r="3.5" fill="rgba(192,72,32,0.7)" />
              </>
            )}
            <!-- Tracker dot — follows cursor, projected onto the route path -->
            <circle class="map-tracker-dot" cx="0" cy="0" r="6" fill="var(--rust)" />
            <circle class="map-tracker-halo" cx="0" cy="0" r="14" fill="none" stroke="var(--rust)" stroke-width="1" opacity="0.4" />
          </svg>

          <div class="trip-map-coords">
            <span class="trip-map-pin"></span>
            {trip.coords}
          </div>
        </div>
      </div>

      <!-- ── Field Journal + TOC sidebar ──────────────────────────────── -->
      <section class={`trip-journal${hasSidebar ? '' : ' trip-journal--no-sidebar'}`}>

        <div class="journal-entries">
          <div class="trip-journal-eyebrow">Field Journal</div>
          <div class="trip-story-inner">

            {storyProcessed.map((block: any) => {

              // ── Section header (Overview / Day / Final / Custom) ──────
              if (block.type === 'dayEntry') return (
                <div class="story-block story-section" id={block._anchor}>
                  <div class="story-section-header">
                    {block._bigNum && (
                      <div class="story-section-number">{block._bigNum}</div>
                    )}
                    <div class="story-section-meta">
                      <span class="story-section-label">{block._eyebrow}</span>
                      <span class="story-section-title">{block.dayTitle}</span>
                    </div>
                  </div>
                </div>
              )

              // ── Hindsight ─────────────────────────────────────────────
              if (block.type === 'hindsight') return (
                <div class="story-block trip-hindsight">
                  <div class="hindsight-label">What We'd Do Differently</div>
                  {block.richText?.length ? (
                    <div class="hindsight-body trip-paragraph" set:html={toHTML(block.richText, { components: ptComponents })} />
                  ) : block.content ? (
                    <p class="hindsight-body">{block.content}</p>
                  ) : null}
                </div>
              )

              // ── Story divider ─────────────────────────────────────────
              if (block.type === 'divider') return (
                <div class="story-block story-divider" role="separator">
                  <span class="story-divider-mark">✦</span>
                </div>
              )

              // ── Callout ───────────────────────────────────────────────
              if (block.type === 'callout') return (
                <div class="story-block story-callout">
                  {block.content}
                </div>
              )

              // ── Single image ──────────────────────────────────────────
              if (block.type === 'image' && block.image) return (
                <figure class="story-block story-img lb-trigger" data-lightbox-idx={lbByKey.get(block._key) ?? -1}>
                  <img
                    src={urlFor(block.image).width(1200).quality(85).format('webp').url()}
                    srcset={sanityImgSrcset(block.image, [600, 900, 1200, 1800], 85)}
                    sizes="(max-width: 768px) 100vw, 860px"
                    width={block.image.dims?.width}
                    height={block.image.dims?.height}
                    alt={block.image.alt ?? ''}
                    loading="lazy"
                    decoding="async"
                  />
                  {block.image.caption && (
                    <figcaption class="story-caption">{block.image.caption}</figcaption>
                  )}
                </figure>
              )

              // ── Photo strip (gallery with layout=strip) ───────────────
              if (block.type === 'gallery' && block.layout === 'strip' && block.images?.length) return (
                <div class="story-block story-strip">
                  {block.images.map((img: any) => (
                    <figure class="story-strip-item lb-trigger" data-lightbox-idx={lbByKey.get(img._key) ?? -1}>
                      <img
                        src={urlFor(img).width(800).quality(85).format('webp').url()}
                        srcset={sanityImgSrcset(img, [400, 600, 800], 85)}
                        sizes="(max-width: 768px) 100vw, 33vw"
                        width={img.dims?.width}
                        height={img.dims?.height}
                        alt={img.alt ?? ''}
                        loading="lazy"
                        decoding="async"
                      />
                    </figure>
                  ))}
                </div>
              )

              // ── Gallery grid ──────────────────────────────────────────
              if (block.type === 'gallery' && block.images?.length) return (
                <div class="story-block story-gallery" style={`--cols:${Math.min(block.images.length, 4)}`}>
                  {block.images.map((img: any) => (
                    <figure class="story-gallery-item lb-trigger" data-lightbox-idx={lbByKey.get(img._key) ?? -1}>
                      <img
                        src={urlFor(img).width(800).quality(85).format('webp').url()}
                        srcset={sanityImgSrcset(img, [400, 600, 800], 85)}
                        sizes="(max-width: 768px) 100vw, 25vw"
                        width={img.dims?.width}
                        height={img.dims?.height}
                        alt={img.alt ?? ''}
                        loading="lazy"
                        decoding="async"
                      />
                      {img.caption && <figcaption class="story-caption">{img.caption}</figcaption>}
                    </figure>
                  ))}
                </div>
              )

              // ── Video ─────────────────────────────────────────────────
              if (block.type === 'video' && block.url) return (
                <div class="story-block story-video">
                  <iframe
                    src={getEmbedUrl(block.url)}
                    title={`${trip.pageTitle?.join(' ')} — video`}
                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                    allowfullscreen
                  />
                </div>
              )

              // ── Pull quote ────────────────────────────────────────────
              if (block.type === 'quote') return (
                <blockquote
                  class="story-block trip-pull-quote"
                  style={`--accent:${trip.accentColor}`}
                >
                  {block.content}
                </blockquote>
              )

              // ── Text (Portable Text) ──────────────────────────────────
              if (block.type === 'text' && block.richText?.length) return (
                <div class="story-block trip-paragraph" set:html={toHTML(block.richText, { components: ptComponents })} />
              )

              // ── Plain text fallback ───────────────────────────────────
              return (
                <p class="story-block trip-paragraph">
                  {block.content}
                </p>
              )
            })}

          </div>
        </div>

        <!-- TOC sidebar — only when day entries exist -->
        {hasSidebar && (
          <aside class="journal-sidebar">
            <div class="journal-toc-note">
              <div class="toc-note-label">In This Entry</div>
              {dayEntries.map(d => (
                <a href={`#${d.id}`} class="toc-item">
                  <span class="toc-num">{d.num}</span>
                  <span class="toc-text">{d.title}</span>
                </a>
              ))}
            </div>
          </aside>
        )}

      </section>
    </div>

    <!-- ── Next expedition ───────────────────────────────────────────────── -->
    {nextTrip && (
      <section class="trip-next">
        <div class="trip-next-label">Next Expedition</div>
        <button
          class="trip-next-card"
          id="next-trip-card"
          data-src={nextUrl}
          data-href={`/expedition/${nextTrip.id}`}
          data-hero-url={nextHeroUrl}
          style={`--accent:${nextTrip.accentColor}`}
        >
          <div class="trip-next-img-wrap">
            <img
              src={nextUrl}
              srcset={nextSrcset}
              sizes="(max-width: 768px) 100vw, 600px"
              alt={nextTrip.heroImage?.alt ?? nextTrip.location}
              loading="lazy"
              decoding="async"
            />
            {nextTrip.cardVideoUrl && (
              <video
                class="exp-card-video"
                data-src={nextTrip.cardVideoUrl}
                muted
                loop
                playsinline
                preload="none"
                aria-hidden="true"
              />
            )}
          </div>
          <div class="trip-next-overlay"></div>
          <div class="trip-next-content">
            <span class="trip-next-num">{String(nextIndex + 1).padStart(2, '0')}</span>
            <span class="trip-next-title">{nextTrip.pageTitle?.join(' ')}</span>
            <span class="trip-next-arrow">→</span>
          </div>
        </button>
      </section>
    )}

  </div>

  <!-- ── Elevation profile sidebar ──────────────────────────────────────── -->
  <aside
    class="elev-sidebar"
    aria-label="Elevation profile"
    aria-hidden="true"
    data-points={JSON.stringify(elevPoints)}
    data-svg-points={JSON.stringify(svgPoints)}
  >
    <svg
      class="elev-svg"
      viewBox="0 0 36 160"
      preserveAspectRatio="none"
      xmlns="http://www.w3.org/2000/svg"
      aria-hidden="true"
    >
      <polygon points={fillPoints} class="elev-fill" />
      <polyline points={pointsStr} class="elev-line" />
      <text x="2" y={svgYPad + svgYH + 2} class="elev-label" dominant-baseline="hanging">
        {Math.round(elMin).toLocaleString()}
      </text>
      <text x="2" y={svgYPad - 2} class="elev-label" dominant-baseline="auto">
        {Math.round(elMax).toLocaleString()}
      </text>
      <circle id="elev-dot" cx={firstX} cy={firstY} r="3.5" class="elev-dot" style={`fill:${trip.accentColor}`} />
      <text id="elev-readout" x={firstX + 5} y={firstY} class="elev-readout" dominant-baseline="middle">
        {Math.round(elevPoints[0]).toLocaleString()} ft
      </text>
    </svg>
    <div class="elev-unit">ft</div>
  </aside>

  <!-- ── Elevation strip (mobile) ─────────────────────────────────────────── -->
  <div
    class="elev-strip"
    aria-hidden="true"
    data-strip-points={JSON.stringify(svgStripPoints)}
  >
    <svg
      class="elev-strip-svg"
      viewBox={`0 0 ${stripW} ${stripH}`}
      preserveAspectRatio="none"
      xmlns="http://www.w3.org/2000/svg"
      aria-hidden="true"
    >
      <polygon points={stripFillPoints} class="elev-fill" />
      <polyline points={stripPointsStr} class="elev-line" />
      <circle id="elev-dot-h" cx={stripFirstX} cy={stripFirstY} r="4" class="elev-dot" style={`fill:${trip.accentColor}`} />
    </svg>
  </div>

  <!-- ── Lightbox ────────────────────────────────────────────────────────── -->
  {lightboxImages.length > 0 && (
    <>
      <div class="lightbox" id="lightbox" role="dialog" aria-modal="true" aria-label="Photo viewer" hidden>
        <div class="lightbox-bg" id="lightbox-bg"></div>
        <button class="lightbox-close" id="lightbox-close" aria-label="Close lightbox">✕</button>
        <button class="lightbox-prev" id="lightbox-prev" aria-label="Previous photo">←</button>
        <button class="lightbox-next" id="lightbox-next" aria-label="Next photo">→</button>
        <figure class="lightbox-figure">
          <img id="lightbox-img"      class="lightbox-img lightbox-img-a" src="" alt="" />
          <img id="lightbox-img-next" class="lightbox-img lightbox-img-b" src="" alt="" aria-hidden="true" />
        </figure>
        <div class="lightbox-bar">
          <span id="lightbox-caption" class="lightbox-caption"></span>
          <span id="lightbox-counter" class="lightbox-counter" style={`--accent:${trip.accentColor}`}></span>
        </div>
      </div>

      <script define:vars={{ lightboxImages, accentColor: trip.accentColor }}>
        let current = 0
        const lb        = document.getElementById('lightbox')
        const bg        = document.getElementById('lightbox-bg')
        const imgA      = document.getElementById('lightbox-img')
        const imgB      = document.getElementById('lightbox-img-next')
        const captionEl = document.getElementById('lightbox-caption')
        const counterEl = document.getElementById('lightbox-counter')
        const closeBtn  = document.getElementById('lightbox-close')
        const prevBtn   = document.getElementById('lightbox-prev')
        const nextBtn   = document.getElementById('lightbox-next')

        const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches
        let activeImg = imgA
        let inactiveImg = imgB

        // Shared helper — combine centering translate with an optional
        // scale and x-offset so all transforms stay in one declaration.
        const setTransform = (img, { scale = 1, x = 0, blur = 0, rotate = 0 } = {}) => {
          img.style.transform = `translate(calc(-50% + ${x}px), -50%) scale(${scale}) rotate(${rotate}deg)`
          img.style.filter = blur > 0 ? `blur(${blur}px)` : ''
        }
        const resetTransform = img => setTransform(img)

        function open(idx) {
          current = ((idx % lightboxImages.length) + lightboxImages.length) % lightboxImages.length
          lb.hidden = false
          document.body.style.overflow = 'hidden'
          inactiveImg.style.opacity = '0'
          activeImg.style.opacity = '0'
          activeImg.src = lightboxImages[current].src
          activeImg.alt = lightboxImages[current].alt

          if (!prefersReducedMotion) setTransform(activeImg, { scale: 1.06, blur: 6 })

          const showActive = () => {
            // Force reflow so the start-state transform is painted before
            // the transition begins — without this the scale jump is skipped.
            activeImg.offsetHeight
            activeImg.style.opacity = '1'
            if (!prefersReducedMotion) resetTransform(activeImg)
          }
          if (activeImg.complete && activeImg.naturalWidth > 0) showActive()
          else activeImg.onload = showActive

          updateMeta()
          lb.focus()
          document.addEventListener('keydown', onKey)
        }

        function close() {
          if (prefersReducedMotion) {
            lb.hidden = true
            document.body.style.overflow = ''
            document.removeEventListener('keydown', onKey)
            return
          }
          // Image scales + blurs out as it fades — feels like releasing
          activeImg.style.opacity = '0'
          setTransform(activeImg, { scale: 1.04, blur: 5 })
          setTimeout(() => {
            lb.hidden = true
            document.body.style.overflow = ''
            resetTransform(activeImg)
            resetTransform(inactiveImg)
            document.removeEventListener('keydown', onKey)
          }, 230)
        }

        // dir: 1 = forward (next), -1 = backward (prev)
        function goTo(idx, dir = 1) {
          const next = ((idx % lightboxImages.length) + lightboxImages.length) % lightboxImages.length
          if (next === current) return
          current = next
          const img = lightboxImages[current]

          if (prefersReducedMotion) {
            activeImg.src = img.src
            activeImg.alt = img.alt
            updateMeta()
            return
          }

          // Cancel any in-flight load from a previous rapid navigation
          inactiveImg.onload = null
          inactiveImg.src = img.src
          inactiveImg.alt = img.alt
          inactiveImg.style.opacity = '0'
          // New image starts offset in the direction of travel, slightly blurred + tilted
          setTransform(inactiveImg, { x: dir * 55, scale: 0.94, blur: 10, rotate: dir * -1.2 })

          const doSwap = () => {
            inactiveImg.offsetHeight  // force reflow before transition
            // New image slides to centre, clears blur; old image exits blurred the opposite side
            inactiveImg.style.opacity = '1'
            resetTransform(inactiveImg)
            activeImg.style.opacity = '0'
            setTransform(activeImg, { x: dir * -55, scale: 0.94, blur: 10, rotate: dir * 1.2 })
            setTimeout(() => {
              ;[activeImg, inactiveImg] = [inactiveImg, activeImg]
              // Reset the newly-inactive slot for the next navigation
              inactiveImg.style.opacity = '0'
              resetTransform(inactiveImg)
            }, 300)
          }

          if (inactiveImg.complete && inactiveImg.naturalWidth > 0) doSwap()
          else inactiveImg.onload = doSwap
          updateMeta()
        }

        function updateMeta() {
          const img = lightboxImages[current]
          if (captionEl) captionEl.textContent = img.caption || ''
          if (counterEl) {
            const pad = n => String(n).padStart(2, '0')
            counterEl.textContent = `${pad(current + 1)} / ${pad(lightboxImages.length)}`
          }
          if (bg) {
            const colour = img.palette || accentColor || '#1A1410'
            bg.style.background = hexToRgba(colour, 0.22)
          }
        }

        function hexToRgba(hex, alpha) {
          const r = parseInt(hex.slice(1, 3), 16)
          const g = parseInt(hex.slice(3, 5), 16)
          const b = parseInt(hex.slice(5, 7), 16)
          return `rgba(${r},${g},${b},${alpha})`
        }

        function onKey(e) {
          if (e.key === 'Escape')     { close(); return }
          if (e.key === 'ArrowRight') goTo(current + 1,  1)
          if (e.key === 'ArrowLeft')  goTo(current - 1, -1)
        }

        let touchStartX = 0
        lb.addEventListener('touchstart', e => { touchStartX = e.touches[0].clientX }, { passive: true })
        lb.addEventListener('touchend', e => {
          const dx = e.changedTouches[0].clientX - touchStartX
          if (Math.abs(dx) > 50) dx < 0 ? goTo(current + 1, 1) : goTo(current - 1, -1)
        }, { passive: true })

        document.querySelectorAll('.lb-trigger').forEach(el => {
          el.addEventListener('click', () => {
            const idx = parseInt(el.dataset.lightboxIdx ?? '-1', 10)
            if (idx >= 0) open(idx)
          })
        })

        closeBtn?.addEventListener('click', close)
        prevBtn?.addEventListener('click', () => goTo(current - 1, -1))
        nextBtn?.addEventListener('click', () => goTo(current + 1,  1))

        lb.addEventListener('click', e => {
          if (e.target === lb || e.target === bg) close()
        })
      </script>
    </>
  )}

</BaseLayout>
