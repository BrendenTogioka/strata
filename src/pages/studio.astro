---
// Static HTML shell for Sanity Studio.
// Studio is a React SPA — it mounts client-side and manages its own routing.
// Deep-link refreshes (e.g. /studio/desk/trip) will land here and Studio
// restores state from the URL — no server routes needed for local editing.
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Strata Studio</title>
    <meta name="robots" content="noindex, nofollow" />
    <style>
      html, body, #root { margin: 0; padding: 0; height: 100%; }
      body { background: #101112; }
    </style>
  </head>
  <body>
    <div id="root"></div>
    <script type="module" src="/src/components/StudioMount.tsx"></script>
  </body>
</html>
