---
import BaseLayout from '../layouts/BaseLayout.astro'
import SiteFooter from '../components/SiteFooter.astro'
import { client, urlFor } from '../lib/sanity'
import { GEAR_QUERY } from '../lib/queries'

const gear = await client.fetch(GEAR_QUERY)

// ── Category metadata ──────────────────────────────────────────────────────
const CATEGORY_LABELS: Record<string, string> = {
  camera:      'Camera Body',
  lens:        'Lens',
  tripod:      'Tripod & Support',
  filter:      'Filters & Glass',
  audio:       'Audio',
  accessories: 'Accessories',
  pack:        'Pack & Carry',
  shelter:     'Shelter',
  sleep:       'Sleep',
  kitchen:     'Kitchen',
  navigation:  'Navigation',
  clothing:    'Clothing',
  nutrition:   'Food & Water',
  electronics: 'Electronics',
  safety:      'Safety',
  misc:        'Misc',
}

// Map fine-grained categories → top-level filter group
const CAMERA_CATS      = new Set(['camera', 'lens', 'tripod', 'filter', 'audio', 'accessories'])
const BACKPACKING_CATS = new Set(['pack', 'shelter', 'sleep', 'kitchen', 'navigation', 'clothing', 'nutrition', 'electronics', 'safety', 'misc'])

function groupOf(cat: string) {
  if (CAMERA_CATS.has(cat))      return 'camera'
  if (BACKPACKING_CATS.has(cat)) return 'backpacking'
  return 'other'
}

// Top-level group headers — mirror the Field Kit's mono category labels.
const GROUP_LABELS: Record<string, string> = {
  camera:      'Camera',
  backpacking: 'Backpacking',
  other:       'Other',
}
const GROUP_ORDER = ['camera', 'backpacking', 'other']

// ── Weight formatting ───────────────────────────────────────────────────────
// "1 lb 9.3 oz" above a pound, otherwise "9.3 oz". Matches the expedition Field Kit.
function fmtOz(oz: number) {
  if (!oz || oz <= 0) return ''
  if (oz < 16) return `${oz.toFixed(1)} oz`
  const lb = Math.floor(oz / 16)
  const rem = oz - lb * 16
  return rem >= 0.05 ? `${lb} lb ${rem.toFixed(1)} oz` : `${lb} lb`
}

const totalOz = gear.reduce((s: number, g: any) => s + (g.weightOz ?? 0), 0)

// Group into Camera → Backpacking sections. Within each: featured first, then
// alphabetical by name. Empty groups are dropped.
const gearGroups = GROUP_ORDER
  .map(key => {
    const items = gear
      .filter((g: any) => groupOf(g.category) === key)
      .sort((a: any, b: any) => {
        if (!!a.featured !== !!b.featured) return a.featured ? -1 : 1
        return (a.name ?? '').localeCompare(b.name ?? '')
      })
    const oz = items.reduce((s: number, g: any) => s + (g.weightOz ?? 0), 0)
    return { key, label: GROUP_LABELS[key] ?? key, items, oz }
  })
  .filter(g => g.items.length > 0)
---

<BaseLayout
  title="Gear — Our Roaming Reels"
  description="The camera and backpacking kit I carry into the field. Every piece earns its weight."
>
  <div class="gear-page">

    <header class="gear-header">
      <p class="gear-eyebrow">FIELD KIT</p>
      <h1 class="gear-title">THE GEAR</h1>
      <p class="gear-count">
        <span id="gear-count-num">{gear.length}</span> items{totalOz > 0 && (
          <> · <span id="gear-count-weight">{fmtOz(totalOz)}</span></>
        )}
      </p>

      <!-- Viewfinder reticle — draws in as the header fades, JS fades the SVG in -->
      <svg class="gear-reticle" viewBox="0 0 70 70" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <!-- Outer dashed ring — marching ants -->
        <circle class="reticle-ring" cx="35" cy="35" r="30"/>
        <!-- Corner brackets — draw in sequentially -->
        <path class="reticle-bracket" d="M 4,18 L 4,4 L 18,4"/>
        <path class="reticle-bracket" d="M 52,4 L 66,4 L 66,18"/>
        <path class="reticle-bracket" d="M 66,52 L 66,66 L 52,66"/>
        <path class="reticle-bracket" d="M 18,66 L 4,66 L 4,52"/>
        <!-- Crosshair arms with center gap -->
        <line class="reticle-cross" x1="35" y1="18" x2="35" y2="29"/>
        <line class="reticle-cross" x1="35" y1="41" x2="35" y2="52"/>
        <line class="reticle-cross" x1="18" y1="35" x2="29" y2="35"/>
        <line class="reticle-cross" x1="41" y1="35" x2="52" y2="35"/>
        <!-- Center dot -->
        <circle class="reticle-dot" cx="35" cy="35" r="2.5" fill="var(--rust)"/>
      </svg>
    </header>

    <!-- Filter bar -->
    <div class="gear-bar">
      <div class="filter-group">
        <div class="filter-pills" id="gear-filters">
          <button class="filter-pill active" data-group="">All</button>
          <button class="filter-pill" data-group="camera">Camera</button>
          <button class="filter-pill" data-group="backpacking">Backpacking</button>
        </div>
      </div>
    </div>

    <!-- Grouped sections — Camera, then Backpacking -->
    {gear.length > 0 ? (
      <div class="gear-groups" id="gear-groups">
        {gearGroups.map(group => (
          <section class="gear-group" data-group={group.key}>
            <div class="gear-group-head">
              <span class="gear-group-name">{group.label}</span>
              <span class="gear-group-meta">
                <span class="gear-group-count">{group.items.length} items</span>
                {group.oz > 0 && (
                  <span class="gear-group-weight">{fmtOz(group.oz)}</span>
                )}
              </span>
            </div>
            <ul class="gear-grid">
              {group.items.map((item: any) => {
                const catLabel = CATEGORY_LABELS[item.category] ?? item.category
                const imgUrl = item.image
                  ? urlFor(item.image).width(600).quality(85).format('webp').url()
                  : null

                return (
                  <li
                    class={`gear-card${item.featured ? ' gear-card--featured' : ''}`}
                    data-group={group.key}
                    data-weight={item.weightOz ?? 0}
                  >
                    {imgUrl && (
                      <div class="gear-card-img-wrap">
                        <img
                          src={imgUrl}
                          alt={item.image?.alt ?? item.name}
                          loading="lazy"
                          decoding="async"
                          width={item.image?.dims?.width}
                          height={item.image?.dims?.height}
                        />
                      </div>
                    )}
                    <div class="gear-card-body">
                      <div class="gear-card-meta">
                        <span class="gear-card-cat">{catLabel}</span>
                        {item.weightOz > 0 && (
                          <span class="gear-card-weight">{fmtOz(item.weightOz)}</span>
                        )}
                      </div>
                      <p class="gear-card-name">{item.name}</p>
                      {item.brand && (
                        <p class="gear-card-brand">{item.brand}</p>
                      )}
                      {item.description && (
                        <>
                          <button class="gear-card-toggle" type="button" aria-expanded="false">
                            <span class="gear-card-toggle-label">Details</span>
                            <span class="gear-card-toggle-icon" aria-hidden="true">+</span>
                          </button>
                          <div class="gear-card-detail">
                            <p class="gear-card-desc">{item.description}</p>
                          </div>
                        </>
                      )}
                    </div>
                  </li>
                )
              })}
            </ul>
          </section>
        ))}
      </div>
    ) : (
      <div class="gear-empty">
        <p class="gear-empty-msg">Gear list coming soon.</p>
        <p class="gear-empty-sub">Add items in the Studio to populate this page.</p>
      </div>
    )}

    <SiteFooter />
  </div>
</BaseLayout>

<script>
  function initGear() {
    const groupsWrap = document.getElementById('gear-groups')
    const pills      = document.querySelectorAll<HTMLButtonElement>('#gear-filters .filter-pill')
    if (!pills.length) return

    let activeGroup = ''

    const numEl    = document.getElementById('gear-count-num')
    const weightEl = document.getElementById('gear-count-weight')

    // "1 lb 9.3 oz" above a pound, else "9.3 oz" — mirrors the Astro fmtOz.
    function fmtOz(oz: number) {
      if (!oz || oz <= 0) return ''
      if (oz < 16) return `${oz.toFixed(1)} oz`
      const lb = Math.floor(oz / 16)
      const rem = oz - lb * 16
      return rem >= 0.05 ? `${lb} lb ${rem.toFixed(1)} oz` : `${lb} lb`
    }

    function applyFilter() {
      if (!groupsWrap) return
      let count = 0, oz = 0
      groupsWrap.querySelectorAll<HTMLElement>('.gear-group').forEach(section => {
        const g = section.dataset.group ?? ''
        const visible = !activeGroup || g === activeGroup
        section.style.display = visible ? '' : 'none'
        if (visible) {
          section.querySelectorAll<HTMLElement>('.gear-card').forEach(card => {
            count++
            oz += parseFloat(card.dataset.weight ?? '0') || 0
          })
        }
      })
      if (numEl)    numEl.textContent = String(count)
      if (weightEl) weightEl.textContent = fmtOz(oz)
    }

    pills.forEach(pill => {
      pill.addEventListener('click', () => {
        pills.forEach(p => p.classList.remove('active'))
        pill.classList.add('active')
        activeGroup = pill.dataset.group ?? ''
        applyFilter()
      })
    })

    // Tap-to-expand details (mobile). The toggle is hidden on desktop where
    // descriptions show inline, so this is a no-op there.
    groupsWrap?.querySelectorAll<HTMLButtonElement>('.gear-card-toggle').forEach(btn => {
      btn.addEventListener('click', () => {
        const card = btn.closest<HTMLElement>('.gear-card')
        if (!card) return
        const expanded = card.classList.toggle('is-expanded')
        btn.setAttribute('aria-expanded', String(expanded))
        const label = btn.querySelector('.gear-card-toggle-label')
        if (label) label.textContent = expanded ? 'Hide' : 'Details'
      })
    })
  }

  document.addEventListener('astro:page-load', initGear)
</script>
