---
import { ClientRouter } from 'astro:transitions'
import '../styles/global.css'
import Navigation from '../components/Navigation.astro'

interface Props {
  title?:         string
  description?:   string
  ogImage?:       string
  ogImageWidth?:  number
  ogImageHeight?: number
  ogType?:        'website' | 'article'
  isExpedition?:  boolean
  preloadImage?:  string
}

const {
  title          = 'Our Roaming Reels — A Field Journal',
  description    = 'Adventures written in stone, fire, ice and root. A field journal from the edges of the earth.',
  ogImage        = 'https://res.cloudinary.com/dlle6kl4n/video/upload/so_0/v1779945286/OurRoamingReels/Sequence_07_psmvmg.jpg',
  ogImageWidth,
  ogImageHeight,
  ogType         = 'website',
  isExpedition   = false,
  preloadImage,
} = Astro.props

const canonical = new URL(Astro.url.pathname, Astro.site).href
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0C0906" />
    <title>{title}</title>

    <!-- Always land at the top on (re)load. With the pinned hero, browser
         scroll-restoration would otherwise drop the user mid-pin. We force
         scrollTo(0,0) at parse, on pageshow (covers bfcache), and on load
         (after the browser would have restored). Skip when a #hash is present
         so anchor jumps still work. -->
    <script is:inline>
      if ('scrollRestoration' in history) history.scrollRestoration = 'manual'
      const __toTop = () => { if (!location.hash) scrollTo(0, 0) }
      __toTop()
      addEventListener('pageshow', __toTop)
      addEventListener('load',     __toTop)
    </script>
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type"        content={ogType} />
    <meta property="og:site_name"   content="Our Roaming Reels" />
    <meta property="og:url"         content={canonical} />
    <meta property="og:title"       content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image"       content={ogImage} />
    {ogImageWidth  && <meta property="og:image:width"  content={String(ogImageWidth)} />}
    {ogImageHeight && <meta property="og:image:height" content={String(ogImageHeight)} />}

    <!-- Twitter / X -->
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image"       content={ogImage} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Preload the page's LCP hero image (passed per-page) for fastest paint -->
    {preloadImage && (
      <link rel="preload" as="image" href={preloadImage} fetchpriority="high" />
    )}

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Cormorant+Garamond:ital,wght@0,400;0,500;1,400&family=Space+Mono:wght@400;700&display=swap"
      rel="stylesheet"
    />

    <!-- Astro client-side router (View Transitions + astro:* events) -->
    <ClientRouter />

    <!-- Per-page head extras (e.g. JSON-LD structured data) -->
    <slot name="head" />
  </head>

  <body>
    <!-- Skip link — first focusable element for keyboard users -->
    <a href="#main" class="skip-link">Skip to content</a>

    <!-- Film-grain overlay — temporarily disabled. Restore by uncommenting. -->
    <!-- <div class="grain" aria-hidden="true"></div> -->

    <!-- Custom cursor — transition:persist keeps these elements alive across
         page swaps so the RAF loop never needs to restart. -->
    <div class="cursor"      id="cursor"      transition:persist aria-hidden="true"></div>
    <div class="cursor-ring" id="cursor-ring" transition:persist aria-hidden="true"></div>

    <!-- Page content -->
    <div class="content" transition:animate="none">
      <Navigation isExpedition={isExpedition} />
      <main id="main" tabindex="-1">
        <slot />
      </main>
    </div>
  </body>
</html>

<script>
  import Lenis from 'lenis'
  import { gsap } from 'gsap'
  import { ScrollTrigger } from 'gsap/ScrollTrigger'
  import { playIrisTransition } from '../utils/irisTransition'
  import { playCurtainTransition } from '../utils/curtainTransition'

  gsap.registerPlugin(ScrollTrigger)

  const isTouch  = () => window.matchMedia('(hover: none) and (pointer: coarse)').matches
  const reduceMotion = () => window.matchMedia('(prefers-reduced-motion: reduce)').matches

  // ── Trip title fit-to-width ────────────────────────────────────────────
  // The hero title is sized with a viewport-based clamp for maximum impact,
  // but a long word (e.g. "NARROWS") can exceed the available width and get
  // clipped by .trip-title { overflow: hidden }. Reset to the CSS size, then
  // shrink the font only if the widest line overflows — short words like
  // "FIRE" stay huge, long words scale down to fit. Runs after fonts load and
  // on resize so measurements use the actual display face (Bebas Neue).
  function fitTripTitles() {
    document.querySelectorAll<HTMLElement>('.trip-title').forEach((title) => {
      const lines = title.querySelectorAll<HTMLElement>('.line')
      if (!lines.length) return
      title.style.fontSize = ''                       // reset to the CSS clamp
      const avail = title.clientWidth
      if (!avail) return
      let widest = 0
      lines.forEach(l => { widest = Math.max(widest, l.scrollWidth) })
      if (widest > avail) {
        const base = parseFloat(getComputedStyle(title).fontSize)
        title.style.fontSize = `${base * (avail / widest) * 0.98}px`
      }
    })
  }

  // ── Module-level state ─────────────────────────────────────────────────
  let lenis:       InstanceType<typeof Lenis> | null = null
  let lenisTicker: ((time: number) => void)   | null = null
  let mm:          ReturnType<typeof gsap.matchMedia> | null = null
  let mmHero:      ReturnType<typeof gsap.matchMedia> | null = null

  // ── Lenis smooth scroll ────────────────────────────────────────────────
  function initLenis() {
    if (isTouch() || reduceMotion()) return

    lenis = new Lenis({
      duration:        1.4,
      easing:          (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
      wheelMultiplier: 1.0,
      touchMultiplier: 0,
      smoothWheel:     true,
      orientation:     'vertical',
    })

    lenis.on('scroll', () => ScrollTrigger.update())

    lenisTicker = (time: number) => lenis!.raf(time * 1000)
    gsap.ticker.add(lenisTicker)
    gsap.ticker.lagSmoothing(0)

    ScrollTrigger.scrollerProxy(document.documentElement, {
      scrollTop: (value?: number) => {
        // Guard: fall back to native scroll if lenis isn't ready yet
        if (!lenis) return document.documentElement.scrollTop || window.scrollY
        if (value !== undefined) lenis.scrollTo(value, { immediate: true })
        return lenis.scroll
      },
      getBoundingClientRect: () => ({
        top: 0, left: 0,
        width:  window.innerWidth,
        height: window.innerHeight,
      }),
    })

    ScrollTrigger.addEventListener('refresh', () => lenis?.resize())
    ScrollTrigger.refresh()

    // If something restored window.scrollY before Lenis read it, Lenis is now
    // out of sync — force both to 0 (unless an #anchor is targeted).
    if (!location.hash) {
      window.scrollTo(0, 0)
      lenis.scrollTo(0, { immediate: true })
    }
  }

  // ── Custom cursor ──────────────────────────────────────────────────────
  // Runs ONCE — cursor elements have transition:persist so the RAF loop
  // never stops and never needs to restart across page swaps.
  function initCursor() {
    if (isTouch()) return

    const cursor = document.getElementById('cursor')
    const ring   = document.getElementById('cursor-ring')
    if (!cursor || !ring) return

    let mx = window.innerWidth  / 2
    let my = window.innerHeight / 2
    let rx = mx, ry = my

    window.addEventListener('mousemove', (e: MouseEvent) => {
      mx = e.clientX
      my = e.clientY
    }, { passive: true })

    const tick = () => {
      rx += (mx - rx) * 0.12
      ry += (my - ry) * 0.12
      cursor.style.transform = `translate(${mx}px, ${my}px) translate(-50%, -50%)`
      ring.style.transform   = `translate(${rx}px, ${ry}px) translate(-50%, -50%)`
      requestAnimationFrame(tick)
    }
    requestAnimationFrame(tick)

    // Expand the cursor ring when hovering interactive elements — one global
    // delegate on document so it works across every page without re-registering.
    const HOVERABLE = 'a, button, [role="button"], .exp-card, .exp-grid-card, .trip-next-card, .filter-pill, .lb-trigger, .sort-select, .toc-item, .back-btn'
    document.addEventListener('mouseover', (e: MouseEvent) => {
      const hit = !!(e.target as HTMLElement)?.closest?.(HOVERABLE)
      cursor.classList.toggle('cursor--hover', hit)
      ring.classList.toggle('cursor-ring--hover', hit)
    }, { passive: true })
  }

  // ── Page animations — called on every astro:page-load ─────────────────
  // All section-level scripts have been removed; this single function
  // owns every GSAP animation so it always runs regardless of which page
  // the user first lands on.
  function initPageAnimations() {

    // ── Reduced motion: show everything in its final state, no animation ──
    // Skips intros, parallax and the iris overlay entirely; elements that the
    // animations would have revealed are set visible up-front.
    if (reduceMotion()) {
      gsap.set([
        '.hero-location', '.hero-sub', '.section-eyebrow', '.section-body',
        '.feature-quote', '.feature-link', '.contact-pre', '.contact-email',
        '.contact-footer', '.trip-stats-bar', '.back-btn', '.story-block',
        '.trip-map-section',
        '.exp-card-num', '.exp-card-title', '.exp-card-meta',
        '.end-cap-rule', '.end-cap-eyebrow', '.end-cap-heading', '.end-cap-arrow-wrap',
        '.trip-intro-eyebrow', '.trip-journal-eyebrow', '.trip-map-eyebrow',
        '.expeditions-eyebrow', '.expeditions-title', '.expeditions-count',
        '.gear-eyebrow', '.gear-title', '.gear-count',
      ], { opacity: 1, x: 0, y: 0 })
      gsap.set([
        '.hero-title .line', '.section-title .line', '.section-title .line-inner',
        '.contact-headline .line', '.trip-title .line',
      ], { y: 0, opacity: 1 })
      // Make CSS-driven elements immediately visible
      document.querySelectorAll<HTMLElement>('.stat, .intel-row, .condition-item').forEach(el => {
        el.classList.add('is-visible')
      })
      document.querySelectorAll<HTMLImageElement>(
        '.story-img img, .story-gallery-item img, .story-strip-item img'
      ).forEach(img => img.classList.add('is-loaded'))
      document.querySelector<HTMLElement>('.iris-overlay')?.remove()
      if (document.querySelector('.trip-page')) {
        fitTripTitles()
        document.fonts?.ready.then(fitTripTitles)
      }
      return
    }

    // ── Iris overlay handoff ────────────────────────────────────────────
    // The overlay from the previous page's iris transition is kept on screen
    // until the destination hero is decoded, then removed in one frame. We do
    // NOT cross-fade it out: the overlay image and the hero are the same photo
    // at the same fullscreen framing, so a fade just layers a second "hero
    // fade-in" on top of the title reveal — which reads as the intro playing
    // twice. A hard cut after the hero has painted is seamless and prevents
    // the dark flash when the hero wasn't cached (e.g. from the expeditions grid).
    const irisOverlay = document.querySelector<HTMLElement>('.iris-overlay')
    if (irisOverlay) {
      const tripHero = document.querySelector<HTMLImageElement>('.trip-hero-img')
      // Wait for both the image decode AND a minimum 140ms — on cached or
      // fast connections decode() resolves synchronously, but the browser
      // still needs a paint cycle to composite the hero before the overlay is
      // safe to remove. Without the floor, a single-frame flash of the
      // accent-colour background can appear between overlay removal and first paint.
      const removeIris = () =>
        requestAnimationFrame(() => requestAnimationFrame(() => irisOverlay.remove()))
      if (tripHero) {
        Promise.all([
          tripHero.decode().catch(() => {}),
          new Promise<void>(r => setTimeout(r, 140)),
        ]).then(removeIris)
      } else {
        setTimeout(() => requestAnimationFrame(() => irisOverlay.remove()), 80)
      }
    }

    // ── Curtain overlay handoff ─────────────────────────────────────────
    // Ink curtain from /expeditions navigation: slide it off the top to reveal.
    const curtain = document.querySelector<HTMLElement>('.curtain-overlay')
    if (curtain) {
      gsap.to(curtain, {
        y:        '-100%',
        duration: 0.55,
        ease:     'power3.inOut',
        onComplete: () => curtain.remove(),
      })
    }

    // ── Hero ────────────────────────────────────────────────────────────
    const heroSection = document.querySelector<HTMLElement>('.hero')
    const heroImgWrap = document.getElementById('hero-img-wrap')
    if (heroSection && heroImgWrap) {
      const tl = gsap.timeline({ delay: 0.2 })
      tl.to('.hero-location', { opacity: 1, y: 0, duration: 0.9, ease: 'power3.out' })
        .to('.hero-title .line', { y: 0, duration: 1.3, stagger: 0.08, ease: 'power4.out' }, '-=0.5')
        .to('.hero-sub',         { opacity: 1, y: 0, duration: 1,   ease: 'power3.out' }, '-=0.7')

      // Parallax only when no scrub video (video scrub drives its own position)
      const heroVideo = document.getElementById('hero-video') as HTMLVideoElement | null
      if (!heroVideo) {
        gsap.to(heroImgWrap, {
          yPercent: 20, ease: 'none',
          scrollTrigger: {
            trigger: heroSection,
            start: 'top top',
            end:   'bottom top',
            scrub: 1,
          },
        })
      }

      // ── Hero video ──────────────────────────────────────────────────────
      // Desktop (≥769px): pin the hero and stretch the scrub over 200% of
      //   viewport-height of scroll — video stays in view ~2× longer.
      // Mobile  (≤768px):  pinning + frame scrubbing on touch feels stuck and
      //   chews battery, so just autoplay the same video as a smooth loop.
      // Reduced motion: skips both — the static poster image remains.
      // Tweak HERO_PIN_SCROLL to taste: '+=150%' ≈ 1.5×, '+=250%' ≈ 2.5×.
      if (heroVideo && !reduceMotion()) {
        const HERO_PIN_SCROLL = '+=200%'
        // Fade the video in once it can play (shared by both desktop and mobile)
        const showHeroVideo = () => { heroVideo.style.opacity = '1' }
        if (heroVideo.readyState >= 2) showHeroVideo()
        else heroVideo.addEventListener('canplay', showHeroVideo, { once: true })

        mmHero = gsap.matchMedia()

        mmHero.add('(min-width: 769px)', () => {
          heroVideo.pause()
          // Only seek once we have enough buffered data to render the next
          // frame instantly — readyState 3 (HAVE_FUTURE_DATA) avoids the
          // "scrub a buffering video" jitter that plagues scrub-video setups.
          const scrub = (progress: number) => {
            if (heroVideo.readyState >= 3 && heroVideo.duration) {
              heroVideo.currentTime = progress * heroVideo.duration
            }
          }
          ScrollTrigger.create({
            trigger: heroSection,
            start: 'top top',
            end:   HERO_PIN_SCROLL,
            pin:   true,
            pinSpacing: true,
            // Numeric scrub = GSAP smooths scroll → progress over N seconds,
            // so onUpdate fires uniformly via rAF instead of every wheel tick.
            // 0.3 balances smooth seek pacing with responsiveness (lower feels
            // snappier but exposes more decoder jitter; raise for smoother).
            scrub: 0.3,
            onUpdate: self => scrub(self.progress),
          })
          return () => { heroVideo.pause() }
        })

        mmHero.add('(max-width: 768px)', () => {
          // Element already has muted/loop/playsinline attrs (HeroSection.astro),
          // so .play() is allowed under autoplay policies.
          heroVideo.play().catch(() => {})
          return () => {
            heroVideo.pause()
            heroVideo.currentTime = 0
          }
        })
      }
    }

    // ── Expedition gallery (horizontal scroll + iris) ────────────────────
    const expSection = document.querySelector<HTMLElement>('.expedition')
    const expTrack   = document.getElementById('expedition-track') as HTMLElement | null
    if (expSection && expTrack) {
      // Cards fade in (0 → 1) as the gallery section enters the viewport.
      // Fully opaque by the time the section's top crosses ~40% from the
      // viewport bottom (i.e. the user has scrolled it into the lower half).
      gsap.set('.exp-card, .exp-end-cap', { opacity: 0 })
      gsap.to('.exp-card, .exp-end-cap', {
        opacity: 1,
        ease: 'none',
        scrollTrigger: {
          trigger: expSection,
          start: 'top 95%',     // small offset before begin = less twitchy
          end:   'top 40%',     // opacity 1 when section top is ~60% from bottom — cards arrive, not appear
          scrub: 0.5,
        },
      })

      mm = gsap.matchMedia()

      mm.add('(min-width: 769px)', () => {
        const cards       = gsap.utils.toArray<HTMLElement>('.exp-card')
        const totalScroll = expTrack.scrollWidth - window.innerWidth

        const hScroll = gsap.to(expTrack, {
          x: () => -totalScroll,
          ease: 'none',
          scrollTrigger: {
            trigger: expSection,
            pin: true,
            scrub: 1.2,
            end: () => `+=${totalScroll}`,
            invalidateOnRefresh: true,
            anticipatePin: 1,
          },
        })

        cards.forEach((card) => {
          // Per-card image parallax
          gsap.to(card.querySelector('.exp-card-img-wrap'), {
            x: 40, ease: 'none',
            scrollTrigger: {
              trigger: card,
              containerAnimation: hScroll,
              start: 'left right',
              end:   'right left',
              scrub: 1,
            },
          })
          // Card text stagger-in
          gsap.to(card.querySelectorAll('.exp-card-num, .exp-card-title, .exp-card-meta'), {
            opacity: 1, y: 0, stagger: 0.08, duration: 0.7, ease: 'power3.out',
            scrollTrigger: {
              trigger: card,
              containerAnimation: hScroll,
              start: 'left 80%',
              toggleActions: 'play none none reverse',
            },
          })
        })

        // End-cap stagger-in
        const endCap = document.querySelector<HTMLElement>('.exp-end-cap')
        if (endCap) {
          gsap.to(endCap.querySelectorAll('.end-cap-rule, .end-cap-eyebrow, .end-cap-heading, .end-cap-arrow-wrap'), {
            opacity: 1, y: 0, stagger: 0.1, duration: 0.8, ease: 'power3.out',
            scrollTrigger: {
              trigger: endCap,
              containerAnimation: hScroll,
              start: 'left 85%',
              toggleActions: 'play none none reverse',
            },
          })
        }
      })

      // Mobile: reveal card text immediately (vertical layout)
      mm.add('(max-width: 768px)', () => {
        gsap.utils.toArray<HTMLElement>('.exp-card-num, .exp-card-title, .exp-card-meta')
          .forEach(el => gsap.set(el, { opacity: 1, y: 0 }))
      })

      // Iris transition on card click — video stops first, iris uses the static image
      document.querySelectorAll<HTMLElement>('.exp-card').forEach((card) => {
        const preloadCardHero = () => {
          const heroUrl = card.dataset.heroUrl
          if (heroUrl && !document.querySelector(`link[rel="preload"][href="${CSS.escape(heroUrl)}"]`)) {
            const link = document.createElement('link')
            link.rel  = 'preload'
            link.as   = 'image'
            link.href = heroUrl
            document.head.appendChild(link)
          }
        }
        card.addEventListener('mouseenter', preloadCardHero, { once: true })

        card.addEventListener('click', (e) => {
          e.preventDefault()
          // Pause any playing card video before iris expands
          card.querySelector<HTMLVideoElement>('.exp-card-video')?.pause()
          const src     = card.dataset.src     ?? ''
          const href    = card.dataset.href    ?? card.getAttribute('href') ?? '/'
          const heroSrc = card.dataset.heroUrl ?? ''
          const img     = card.querySelector<HTMLImageElement>('.exp-card-img-wrap img')
          if (!img || !src) { window.location.href = href; return }
          playIrisTransition({ src, rect: img.getBoundingClientRect(), href, heroSrc })
        })
      })
    }

    // ── Card-video hover preview (.exp-card-video) ────────────────────────
    // Runs on any page that has .exp-card-video elements — home gallery AND
    // the expeditions archive grid. Touch devices autoplay on visibility;
    // mouse devices play on hover. Reduced motion skips entirely.
    if (!reduceMotion()) {
      const cardVideos = document.querySelectorAll<HTMLVideoElement>('.exp-card-video')
      if (cardVideos.length) {
        if (isTouch()) {
          const io = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
              const vid = entry.target as HTMLVideoElement
              if (entry.isIntersecting) {
                if (!vid.src) vid.src = vid.dataset.src ?? ''
                vid.play().catch(() => {})
                vid.classList.add('is-playing')
              } else {
                vid.pause()
                vid.classList.remove('is-playing')
              }
            })
          }, { threshold: 0.5 })
          cardVideos.forEach(v => io.observe(v))
        } else {
          cardVideos.forEach(vid => {
            // Closest card wrapper covers every layout that uses .exp-card-video:
            // .exp-card (home gallery), .exp-grid-card (expeditions archive),
            // .trip-next-card (next-expedition CTA at the bottom of trip pages).
            const card = vid.closest<HTMLElement>('.exp-card, .exp-grid-card, .trip-next-card')
            if (!card) return
            card.addEventListener('mouseenter', () => {
              if (!vid.src) vid.src = vid.dataset.src ?? ''
              vid.play().catch(() => {})
              vid.classList.add('is-playing')
            })
            card.addEventListener('mouseleave', () => {
              vid.pause()
              vid.currentTime = 0
              vid.classList.remove('is-playing')
            })
          })
        }
      }
    }

    // ── Expedition archive grid stagger reveal (/expeditions) ────────────
    // Header and cards stagger in, pairing with the ink-curtain reveal so the
    // user lands on a quietly composing page rather than a finished one.
    const expGrid = document.getElementById('expeditions-grid')
    if (expGrid) {
      // Header — eyebrow/title/count reveal timed to match the curtain lift (0.55s)
      const tl = gsap.timeline({ delay: 0.25 })
      tl.to('.expeditions-eyebrow', { opacity: 1, y: 0, duration: 0.6, ease: 'power3.out' })
        .to('.expeditions-title',   { opacity: 1, y: 0, duration: 0.9, ease: 'power4.out' }, '-=0.35')
        .to('.expeditions-count',   { opacity: 1, y: 0, duration: 0.5, ease: 'power3.out' }, '-=0.5')

      // Cards stagger up — delayed so the header lines (~1.4s total) get a
      // beat to settle before the grid fires. gsap.from's immediateRender
      // hides cards at script init, so they stay invisible during the wait.
      gsap.from('.exp-grid-card', {
        opacity:  0,
        y:        24,
        duration: 0.9,
        stagger:  0.05,
        delay:    1.0,
        ease:     'power3.out',
        scrollTrigger: { trigger: expGrid, start: 'top 85%', once: true },
      })
    }

    // ── Gear page reveal (/gear) ──────────────────────────────────────────
    const gearGrid = document.getElementById('gear-grid')
    if (document.querySelector('.gear-page')) {
      // Header stagger matches the curtain lift timing
      const gearTl = gsap.timeline({ delay: 0.25 })
      gearTl
        .to('.gear-eyebrow', { opacity: 1, y: 0, duration: 0.6, ease: 'power3.out' })
        .to('.gear-title',   { opacity: 1, y: 0, duration: 0.9, ease: 'power4.out' }, '-=0.35')
        .to('.gear-count',   { opacity: 1, y: 0, duration: 0.5, ease: 'power3.out' }, '-=0.5')

      // Cards stagger up — delayed so the title finishes revealing first.
      if (gearGrid) {
        gsap.from('.gear-card', {
          opacity:  0,
          y:        20,
          duration: 0.7,
          stagger:  0.04,
          delay:    1.0,
          ease:     'power3.out',
          scrollTrigger: { trigger: gearGrid, start: 'top 88%', once: true },
        })
      }
    }

    // ── Featured sections (curated homepage trips) ────────────────────────
    // One data-driven block for every .feature section, regardless of layout.
    gsap.utils.toArray<HTMLElement>('.feature').forEach((section) => {
      const imgWrap = section.querySelector<HTMLElement>('.feature-img-wrap')
      if (imgWrap) {
        gsap.to(imgWrap, {
          yPercent: -10, ease: 'none',
          scrollTrigger: { trigger: section, start: 'top bottom', end: 'bottom top', scrub: 1 },
        })
      }
      const eyebrow = section.querySelector('.section-eyebrow')
      if (eyebrow) {
        gsap.to(eyebrow, {
          scrollTrigger: { trigger: section, start: 'top 75%', once: true },
          opacity: 1, y: 0, duration: 0.8, ease: 'power3.out',
        })
      }
      // .line is the clip mask; .line-inner is animated so long words never clip.
      gsap.to(section.querySelectorAll('.section-title .line-inner'), {
        scrollTrigger: { trigger: section, start: 'top 70%', once: true },
        y: 0, stagger: 0.08, duration: 1.2, ease: 'power4.out',
      })
      gsap.to(section.querySelectorAll('.section-body, .feature-quote, .feature-link'), {
        scrollTrigger: { trigger: section, start: 'top 60%', once: true },
        opacity: 1, y: 0, stagger: 0.12, duration: 0.9, ease: 'power3.out',
      })
    })

    // ── Contact section ──────────────────────────────────────────────────
    const contactSection = document.querySelector<HTMLElement>('.contact')
    if (contactSection) {
      gsap.to('.contact-pre', {
        scrollTrigger: { trigger: '.contact', start: 'top 80%', once: true },
        opacity: 1, y: 0, duration: 0.8, ease: 'power3.out',
      })
      gsap.to('.contact-headline .line', {
        scrollTrigger: { trigger: '.contact-headline', start: 'top 85%', once: true },
        y: 0, stagger: 0.09, duration: 1.1, ease: 'power4.out',
      })
      gsap.to('.contact-email, .contact-footer', {
        scrollTrigger: { trigger: '.contact-email', start: 'top 85%', once: true },
        opacity: 1, y: 0, stagger: 0.15, duration: 0.8, ease: 'power3.out',
      })
    }

    // ── Trip page ─────────────────────────────────────────────────────────
    if (document.querySelector('.trip-page')) {
      fitTripTitles()
      document.fonts?.ready.then(fitTripTitles)

      // Hero parallax — image drifts as user scrolls through the hero
      const tripHeroImg = document.querySelector<HTMLElement>('.trip-hero-img')
      if (tripHeroImg && !reduceMotion()) {
        gsap.fromTo(tripHeroImg,
          { yPercent: -8, scale: 1.16 },
          {
            yPercent: 8,
            scale:    1.16,
            ease:     'none',
            scrollTrigger: {
              trigger: '.trip-hero',
              start:   'top top',
              end:     'bottom top',
              scrub:   1,
            },
          }
        )
      }

      // Reset text/hero states — exclude .trip-map-section which has its own
      // chained animation below (it starts visible so parallax measures correctly).
      gsap.set('.trip-title .line', { y: '110%' })
      gsap.set('.trip-stats-bar',   { opacity: 0, y: 20 })
      gsap.set('.back-btn',         { opacity: 0, x: -16 })
      gsap.set('.story-block:not(.trip-map-section)', { opacity: 0, y: 30 })
      // Override the CSS story-block transform so parallax has a clean origin
      gsap.set('.trip-map-section', { opacity: 0, y: 0 })

      // Stats stagger — each .stat ticks in after the bar appears
      const tl = gsap.timeline({ delay: 0.1 })
      tl.to('.trip-title .line', {
          y: 0, duration: 1.1, stagger: 0.07, ease: 'power4.out',
        })
        .to('.trip-stats-bar', {
          opacity: 1, y: 0, duration: 0.7, ease: 'power3.out',
        }, '-=0.7')
        .to('.back-btn', {
          opacity: 1, x: 0, duration: 0.6, ease: 'power3.out',
        }, '-=0.8')
        .call(() => {
          // Stagger .stat elements after bar is visible; CSS handles the transition
          document.querySelectorAll<HTMLElement>('.stat').forEach((s, i) => {
            setTimeout(() => s.classList.add('is-visible'), i * 60)
          })
        }, [], '-=0.3')

      // Generic story-block scroll reveal (excludes the map section)
      gsap.utils.toArray<HTMLElement>('.story-block:not(.trip-map-section)').forEach((block) => {
        gsap.to(block, {
          scrollTrigger: { trigger: block, start: 'top 82%' },
          opacity: 1, y: 0, duration: 0.9, ease: 'power3.out',
        })
      })

      // Field intel rows stagger in after the panel fades in
      const fieldIntel = document.querySelector<HTMLElement>('.trip-field-intel')
      if (fieldIntel) {
        ScrollTrigger.create({
          trigger: fieldIntel,
          start: 'top 75%',
          once: true,
          onEnter: () => {
            fieldIntel.querySelectorAll<HTMLElement>('.intel-row').forEach((row, i) => {
              setTimeout(() => row.classList.add('is-visible'), i * 70)
            })
          },
        })
      }

      // Conditions strip items stagger in
      const conditions = document.querySelector<HTMLElement>('.trip-conditions')
      if (conditions) {
        ScrollTrigger.create({
          trigger: conditions,
          start: 'top 80%',
          once: true,
          onEnter: () => {
            conditions.querySelectorAll<HTMLElement>('.condition-item').forEach((item, i) => {
              setTimeout(() => item.classList.add('is-visible'), i * 80)
            })
          },
        })
      }

      // Story-divider ✦ mark scales + rotates in — editorial flourish
      gsap.utils.toArray<HTMLElement>('.story-divider').forEach((d) => {
        const mark = d.querySelector('.story-divider-mark')
        if (!mark) return
        gsap.from(mark, {
          scale:    0.85,
          rotate:   -90,
          duration: 1.2,
          ease:     'power3.out',
          scrollTrigger: { trigger: d, start: 'top 85%', once: true },
        })
      })

      // Story images — fade in when the lazy load completes
      document.querySelectorAll<HTMLImageElement>(
        '.story-img img, .story-gallery-item img, .story-strip-item img'
      ).forEach(img => {
        const reveal = () => img.classList.add('is-loaded')
        if (img.complete && img.naturalWidth > 0) reveal()
        else img.addEventListener('load', reveal, { once: true })
      })

      // ── Route map motion ────────────────────────────────────────────────
      // Chain on scroll: section fade → path draw-on → topo rings stagger.
      // Path length is recomputed inside onEnter because Chrome occasionally
      // returns 0 from getTotalLength() before first paint after a client-side
      // route swap. Triggers are also slightly more forgiving (top 90% vs 82%)
      // and the path's stroke styles are set in onEnter, so a glitch in the
      // ScrollTrigger never leaves the path locked in its "fully hidden" state.
      const mapSection = document.querySelector<HTMLElement>('.trip-map-section')
      if (mapSection) {
        gsap.to('.trip-map-svg', {
          yPercent: -6, ease: 'none',
          scrollTrigger: { trigger: mapSection, start: 'top bottom', end: 'bottom top', scrub: 1 },
        })

        const routePath = document.querySelector<SVGPathElement>('.map-route-path')
        const rings     = gsap.utils.toArray<Element>('.map-topo-ring')
        if (rings.length) gsap.set(rings, { opacity: 0 })

        ScrollTrigger.create({
          trigger: mapSection,
          start:   'top 90%',
          once:    true,
          onEnter: () => {
            gsap.to(mapSection, { opacity: 1, duration: 0.8, ease: 'power3.out' })

            if (routePath) {
              const pathLen = routePath.getTotalLength()
              if (pathLen > 0) {
                routePath.style.strokeDasharray  = `${pathLen}`
                routePath.style.strokeDashoffset = `${pathLen}`
                gsap.to(routePath, {
                  strokeDashoffset: 0,
                  ease:    'power2.inOut',
                  duration: 2,
                  delay:    0.35,
                  onComplete: () => {
                    routePath.style.strokeDasharray  = ''
                    routePath.style.strokeDashoffset = ''
                  },
                })
              }
            }

            if (rings.length) {
              gsap.to(rings, { opacity: 1, stagger: 0.12, duration: 0.8, ease: 'power2.out', delay: 0.4 })
            }
          },
        })
      }

      const nextCard = document.getElementById('next-trip-card')
      if (nextCard) {
        // Preload the destination's full-res hero on hover — gives the iris
        // animation (0.75s) a head start so the image is cached on arrival.
        nextCard.addEventListener('mouseenter', () => {
          const heroUrl = nextCard.dataset.heroUrl
          if (heroUrl && !document.querySelector(`link[rel="preload"][href="${CSS.escape(heroUrl)}"]`)) {
            const link = document.createElement('link')
            link.rel = 'preload'
            link.as  = 'image'
            link.href = heroUrl
            document.head.appendChild(link)
          }
        }, { once: true })

        nextCard.addEventListener('click', () => {
          // Pause the hover-preview video so iris uses the static image
          nextCard.querySelector<HTMLVideoElement>('.exp-card-video')?.pause()
          const src     = nextCard.dataset.src     ?? ''
          const href    = nextCard.dataset.href    ?? '/'
          const heroSrc = nextCard.dataset.heroUrl ?? ''
          const img     = nextCard.querySelector<HTMLImageElement>('.trip-next-img-wrap img')
          if (!img || !src) { window.location.href = href; return }
          playIrisTransition({ src, rect: img.getBoundingClientRect(), href, heroSrc })
        })
      }

      // ── TOC smooth-scroll with offset ───────────────────────────────────
      // Native anchor-link jumps bypass Lenis (which owns the scroll position)
      // AND drop the target flush against the viewport top, squishing the
      // section heading. We intercept clicks, then use Lenis (or a native
      // fallback) to glide to the target with breathing room above it.
      const TOC_OFFSET = 96  // px — keeps the heading clear of the nav
      document.querySelectorAll<HTMLAnchorElement>('.toc-item').forEach(link => {
        link.addEventListener('click', (e) => {
          const id = link.getAttribute('href')?.replace(/^#/, '')
          if (!id) return
          const target = document.getElementById(id)
          if (!target) return
          e.preventDefault()
          if (lenis) {
            lenis.scrollTo(target, { offset: -TOC_OFFSET, duration: 1.2 })
          } else {
            const top = target.getBoundingClientRect().top + window.scrollY - TOC_OFFSET
            window.scrollTo({ top, behavior: 'smooth' })
          }
          history.replaceState(null, '', `#${id}`)
        })
      })
    }

    // ── Elevation profile scroll driver ──────────────────────────────────
    const elevSidebar = document.querySelector<HTMLElement>('.elev-sidebar')
    const elevStrip   = document.querySelector<HTMLElement>('.elev-strip')
    if ((elevSidebar || elevStrip) && !reduceMotion()) {
      const elevDot     = document.getElementById('elev-dot')     as SVGCircleElement | null
      const elevReadout = document.getElementById('elev-readout') as SVGTextElement   | null
      const elevDotH    = document.getElementById('elev-dot-h')   as SVGCircleElement | null
      const rawPoints   = elevSidebar?.dataset.points
      const rawSvgPts   = elevSidebar?.dataset.svgPoints
      const rawStripPts = elevStrip?.dataset.stripPoints

      if (rawPoints && rawSvgPts) {
        const elPoints    = JSON.parse(rawPoints)  as number[]
        const svgPoints   = JSON.parse(rawSvgPts)  as { x: number; y: number }[]
        const stripPoints = rawStripPts ? JSON.parse(rawStripPts) as { x: number; y: number }[] : null
        const n           = elPoints.length

        const updateDot = () => {
          const progress = window.scrollY / Math.max(1, document.body.scrollHeight - window.innerHeight)
          const t        = Math.max(0, Math.min(1, progress)) * (n - 1)
          const lo       = Math.floor(t)
          const hi       = Math.min(lo + 1, n - 1)
          const frac     = t - lo

          const elev = elPoints[lo] + frac * (elPoints[hi] - elPoints[lo])

          // Vertical sidebar dot
          if (elevDot) {
            const cx = svgPoints[lo].x + frac * (svgPoints[hi].x - svgPoints[lo].x)
            const cy = svgPoints[lo].y + frac * (svgPoints[hi].y - svgPoints[lo].y)
            elevDot.setAttribute('cx', cx.toFixed(1))
            elevDot.setAttribute('cy', cy.toFixed(1))
            if (elevReadout) {
              elevReadout.setAttribute('x', (cx + 5).toFixed(1))
              elevReadout.setAttribute('y', cy.toFixed(1))
              elevReadout.textContent = `${Math.round(elev).toLocaleString()} ft`
            }
          }

          // Horizontal strip dot
          if (elevDotH && stripPoints) {
            const cx = stripPoints[lo].x + frac * (stripPoints[hi].x - stripPoints[lo].x)
            const cy = stripPoints[lo].y + frac * (stripPoints[hi].y - stripPoints[lo].y)
            elevDotH.setAttribute('cx', cx.toFixed(1))
            elevDotH.setAttribute('cy', cy.toFixed(1))
          }
        }

        window.addEventListener('scroll', updateDot, { passive: true })
        updateDot()
      }
    }

    // Final refresh so all triggers compute correct positions
    ScrollTrigger.refresh()
  }

  // ── Boot ───────────────────────────────────────────────────────────────
  initLenis()
  initCursor()

  // Animations fire on every page load (covers both initial load + transitions)
  document.addEventListener('astro:page-load', initPageAnimations)

  // Curtain transition for any link pointing to /expeditions (nav, gallery
  // end-cap, "All Expeditions" link). One global delegate; document survives
  // Astro swaps so this only registers once. Modifier keys (cmd/ctrl-click
  // for new tab) and non-left clicks are passed through.
  document.addEventListener('click', (e) => {
    if (e.defaultPrevented || e.button !== 0 || e.metaKey || e.ctrlKey || e.shiftKey || e.altKey) return
    const a = (e.target as HTMLElement | null)?.closest?.('a') as HTMLAnchorElement | null
    if (!a) return
    const path = a.getAttribute('href') ?? ''
    if (path === '/expeditions' || path === '/expeditions/' ||
        path === '/gear'        || path === '/gear/') {
      e.preventDefault()
      playCurtainTransition({ href: path })
    }
  })

  // Re-fit hero titles on resize (no-op on pages without a .trip-title)
  let fitRaf = 0
  window.addEventListener('resize', () => {
    cancelAnimationFrame(fitRaf)
    fitRaf = requestAnimationFrame(fitTripTitles)
  }, { passive: true })

  // ── Teardown + reinit between page swaps ──────────────────────────────
  // IMPORTANT: initLenis() must run BEFORE mm.revert() and ScrollTrigger.killAll()
  // so the scrollerProxy has a valid lenis reference when GSAP calls scrollTop()
  // during cleanup. Otherwise, lenis is null → proxy throws → initLenis() never runs.
  document.addEventListener('astro:after-swap', () => {
    if (lenisTicker) { gsap.ticker.remove(lenisTicker); lenisTicker = null }
    if (lenis)       { lenis.destroy(); lenis = null }
    initLenis()                                                    // ← re-create lenis first
    if (mm)          { mm.revert(); mm = null }                    // ← now proxy is valid
    if (mmHero)      { mmHero.revert(); mmHero = null }
    ScrollTrigger.killAll()                                        // ← now proxy is valid
    // Iris overlays are intentionally kept alive here — initPageAnimations
    // fades them out after the destination hero image has loaded, which
    // prevents the flash of unstyled background between navigation events.
  })
</script>
