---
import { ClientRouter } from 'astro:transitions'
import '../styles/global.css'
import Navigation from '../components/Navigation.astro'

interface Props {
  title?:         string
  description?:   string
  ogImage?:       string
  ogImageWidth?:  number
  ogImageHeight?: number
  ogType?:        'website' | 'article'
  isExpedition?:  boolean
  preloadImage?:  string
}

const {
  title          = 'Our Roaming Reels — A Field Journal',
  description    = 'Adventures written in stone, fire, ice and root. A field journal from the edges of the earth.',
  ogImage        = 'https://res.cloudinary.com/dlle6kl4n/video/upload/so_0/v1779987514/OurRoamingReels/hero-bg.jpg',
  ogImageWidth,
  ogImageHeight,
  ogType         = 'website',
  isExpedition   = false,
  preloadImage,
} = Astro.props

const canonical = new URL(Astro.url.pathname, Astro.site).href
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0C0906" />
    <title>{title}</title>

    <!-- Always land at the top on (re)load. With the pinned hero, browser
         scroll-restoration would otherwise drop the user mid-pin. We force
         scrollTo(0,0) at parse, on pageshow (covers bfcache), and on load
         (after the browser would have restored). Skip when a #hash is present
         so anchor jumps still work. -->
    <script is:inline>
      if ('scrollRestoration' in history) history.scrollRestoration = 'manual'
      const __toTop = () => { if (!location.hash) scrollTo(0, 0) }
      __toTop()
      addEventListener('pageshow', __toTop)
      addEventListener('load',     __toTop)
    </script>
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type"        content={ogType} />
    <meta property="og:site_name"   content="Our Roaming Reels" />
    <meta property="og:url"         content={canonical} />
    <meta property="og:title"       content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image"       content={ogImage} />
    {ogImageWidth  && <meta property="og:image:width"  content={String(ogImageWidth)} />}
    {ogImageHeight && <meta property="og:image:height" content={String(ogImageHeight)} />}

    <!-- Twitter / X -->
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image"       content={ogImage} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Preload the page's LCP hero image (passed per-page) for fastest paint -->
    {preloadImage && (
      <link rel="preload" as="image" href={preloadImage} fetchpriority="high" />
    )}

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Cormorant+Garamond:ital,wght@0,400;0,500;1,400&family=Space+Mono:wght@400;700&display=swap"
      rel="stylesheet"
    />

    <!-- Astro client-side router (View Transitions + astro:* events) -->
    <ClientRouter />

    <!-- Per-page head extras (e.g. JSON-LD structured data) -->
    <slot name="head" />
  </head>

  <body>
    <!-- Skip link — first focusable element for keyboard users -->
    <a href="#main" class="skip-link">Skip to content</a>

    <!-- Film-grain overlay — temporarily disabled. Restore by uncommenting. -->
    <!-- <div class="grain" aria-hidden="true"></div> -->

    <!-- Custom cursor — transition:persist keeps these elements alive across
         page swaps so the RAF loop never needs to restart. -->
    <div class="cursor"      id="cursor"      transition:persist aria-hidden="true"></div>
    <div class="cursor-ring" id="cursor-ring" transition:persist aria-hidden="true"></div>

    <!-- Page content — no transition:animate directive so this div is captured
         as part of the root snapshot, not a separate named view-transition layer.
         Named layers render above position:fixed overlays (curtain/iris) and
         cause visible flashes; without the directive the root opacity:0 rule
         in global.css suppresses the snapshot entirely. -->
    <div class="content">
      <Navigation isExpedition={isExpedition} />
      <main id="main" tabindex="-1">
        <slot />
      </main>
    </div>
  </body>
</html>

<script>
  import Lenis from 'lenis'
  import { gsap } from 'gsap'
  import { ScrollTrigger } from 'gsap/ScrollTrigger'
  import { playIrisTransition } from '../utils/irisTransition'
  import { playCurtainTransition } from '../utils/curtainTransition'

  gsap.registerPlugin(ScrollTrigger)

  const isTouch  = () => window.matchMedia('(hover: none) and (pointer: coarse)').matches
  const reduceMotion = () => window.matchMedia('(prefers-reduced-motion: reduce)').matches

  // ── Count-up animation for numeric stat values ─────────────────────────
  // Parses the leading number from .stat-value text (e.g. "47.2 mi",
  // "18,542 ft", "5 days"), animates from 0 to target, preserves any suffix.
  function countUpStat(statEl: HTMLElement) {
    const valEl = statEl.querySelector<HTMLElement>('.stat-value')
    if (!valEl) return
    const text = valEl.textContent ?? ''
    // Match a leading integer or decimal (commas allowed as thousands separator)
    const match = text.match(/^([\d,]+\.?\d*)(.*)$/)
    if (!match) return
    const rawNum = parseFloat(match[1].replace(/,/g, ''))
    if (isNaN(rawNum) || rawNum === 0) return
    const suffix      = match[2]
    const useComma    = rawNum >= 1000
    const decPlaces   = match[1].includes('.') ? (match[1].split('.')[1]?.length ?? 0) : 0
    const duration    = 900  // ms
    const startTime   = performance.now()

    const tick = (now: number) => {
      const progress = Math.min((now - startTime) / duration, 1)
      const eased    = 1 - Math.pow(1 - progress, 3)  // ease-out cubic
      const current  = rawNum * eased
      let formatted: string
      if (useComma)        formatted = Math.round(current).toLocaleString()
      else if (decPlaces)  formatted = current.toFixed(decPlaces)
      else                 formatted = Math.round(current).toString()
      valEl.textContent = formatted + suffix
      if (progress < 1) requestAnimationFrame(tick)
    }
    requestAnimationFrame(tick)
  }

  // ── Trip title fit-to-width ────────────────────────────────────────────
  // The hero title is sized with a viewport-based clamp for maximum impact,
  // but a long word (e.g. "NARROWS") can exceed the available width and get
  // clipped by .trip-title { overflow: hidden }. Reset to the CSS size, then
  // shrink the font only if the widest line overflows — short words like
  // "FIRE" stay huge, long words scale down to fit. Runs after fonts load and
  // on resize so measurements use the actual display face (Bebas Neue).
  function fitTripTitles() {
    document.querySelectorAll<HTMLElement>('.trip-title').forEach((title) => {
      const lines = title.querySelectorAll<HTMLElement>('.line')
      if (!lines.length) return
      title.style.fontSize = ''                       // reset to the CSS clamp
      const avail = title.clientWidth
      if (!avail) return
      let widest = 0
      lines.forEach(l => { widest = Math.max(widest, l.scrollWidth) })
      if (widest > avail) {
        const base = parseFloat(getComputedStyle(title).fontSize)
        title.style.fontSize = `${base * (avail / widest) * 0.98}px`
      }
    })
  }

  // ── Module-level state ─────────────────────────────────────────────────
  let lenis:       InstanceType<typeof Lenis> | null = null
  let lenisTicker: ((time: number) => void)   | null = null
  let mm:          ReturnType<typeof gsap.matchMedia> | null = null
  let mmHero:      ReturnType<typeof gsap.matchMedia> | null = null

  // ── Lenis smooth scroll ────────────────────────────────────────────────
  function initLenis() {
    if (isTouch() || reduceMotion()) return

    lenis = new Lenis({
      duration:        1.4,
      easing:          (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
      wheelMultiplier: 1.0,
      touchMultiplier: 0,
      smoothWheel:     true,
      orientation:     'vertical',
    })

    lenis.on('scroll', () => ScrollTrigger.update())

    lenisTicker = (time: number) => lenis!.raf(time * 1000)
    gsap.ticker.add(lenisTicker)
    gsap.ticker.lagSmoothing(0)

    ScrollTrigger.scrollerProxy(document.documentElement, {
      scrollTop: (value?: number) => {
        // Guard: fall back to native scroll if lenis isn't ready yet
        if (!lenis) return document.documentElement.scrollTop || window.scrollY
        if (value !== undefined) lenis.scrollTo(value, { immediate: true })
        return lenis.scroll
      },
      getBoundingClientRect: () => ({
        top: 0, left: 0,
        width:  window.innerWidth,
        height: window.innerHeight,
      }),
    })

    ScrollTrigger.addEventListener('refresh', () => lenis?.resize())
    ScrollTrigger.refresh()

    // If something restored window.scrollY before Lenis read it, Lenis is now
    // out of sync — force both to 0 (unless an #anchor is targeted).
    if (!location.hash) {
      window.scrollTo(0, 0)
      lenis.scrollTo(0, { immediate: true })
    }
  }

  // ── Custom cursor ──────────────────────────────────────────────────────
  // Runs ONCE — cursor elements have transition:persist so the RAF loop
  // never stops and never needs to restart across page swaps.
  function initCursor() {
    if (isTouch()) return

    const cursor = document.getElementById('cursor')
    const ring   = document.getElementById('cursor-ring')
    if (!cursor || !ring) return

    let mx = window.innerWidth  / 2
    let my = window.innerHeight / 2
    let rx = mx, ry = my

    window.addEventListener('mousemove', (e: MouseEvent) => {
      mx = e.clientX
      my = e.clientY
    }, { passive: true })

    const tick = () => {
      rx += (mx - rx) * 0.12
      ry += (my - ry) * 0.12
      cursor.style.transform = `translate(${mx}px, ${my}px) translate(-50%, -50%)`
      ring.style.transform   = `translate(${rx}px, ${ry}px) translate(-50%, -50%)`
      requestAnimationFrame(tick)
    }
    requestAnimationFrame(tick)

    // Expand the cursor ring when hovering interactive elements — one global
    // delegate on document so it works across every page without re-registering.
    const HOVERABLE = 'a, button, [role="button"], .exp-card, .exp-grid-card, .trip-next-card, .filter-pill, .lb-trigger, .sort-select, .toc-item, .back-btn'
    document.addEventListener('mouseover', (e: MouseEvent) => {
      const hit = !!(e.target as HTMLElement)?.closest?.(HOVERABLE)
      cursor.classList.toggle('cursor--hover', hit)
      ring.classList.toggle('cursor-ring--hover', hit)
    }, { passive: true })
  }

  // ── Page animations — called on every astro:page-load ─────────────────
  // All section-level scripts have been removed; this single function
  // owns every GSAP animation so it always runs regardless of which page
  // the user first lands on.
  function initPageAnimations() {

    // ── Reduced motion: show everything in its final state, no animation ──
    // Skips intros, parallax and the iris overlay entirely; elements that the
    // animations would have revealed are set visible up-front.
    if (reduceMotion()) {
      gsap.set([
        '.hero-location', '.hero-sub', '.section-eyebrow', '.section-body',
        '.feature-quote', '.feature-link',
        '.about-eyebrow', '.about-sub', '.about-body', '.about-img-badge',
        '.contact-pre', '.contact-sub', '.contact-email-label', '.contact-email',
        '.contact-footer', '.trip-stats-bar', '.back-btn', '.story-block',
        '.trip-map-section',
        '.exp-card-num', '.exp-card-title', '.exp-card-meta',
        '.end-cap-rule', '.end-cap-eyebrow', '.end-cap-heading', '.end-cap-arrow-wrap',
        '.trip-intro-eyebrow', '.trip-journal-eyebrow', '.trip-map-eyebrow',
        '.expeditions-eyebrow', '.expeditions-title', '.expeditions-count',
        '.expeditions-bar', '.gear-eyebrow', '.gear-title', '.gear-count', '.gear-bar',
        '.exp-grid-card', '.gear-card',
      ], { opacity: 1, x: 0, y: 0 })
      gsap.set([
        '.hero-title .line', '.section-title .line', '.section-title .line-inner',
        '.about-headline .line-inner', '.contact-headline .line', '.trip-title .line',
      ], { y: 0, opacity: 1 })
      // Make CSS-driven elements immediately visible
      document.querySelectorAll<HTMLElement>('.stat, .intel-row, .condition-item, .about-detail-item').forEach(el => {
        el.classList.add('is-visible')
      })
      document.querySelectorAll<HTMLImageElement>(
        '.story-img img, .story-gallery-item img, .story-strip-item img'
      ).forEach(img => img.classList.add('is-loaded'))
      document.querySelector<HTMLElement>('.iris-overlay')?.remove()
      if (document.querySelector('.trip-page')) {
        fitTripTitles()
        document.fonts?.ready.then(fitTripTitles)
      }
      return
    }

    // ── Iris overlay handoff ────────────────────────────────────────────
    // The overlay from the previous page's iris transition is kept on screen
    // until the destination hero has actually painted, then removed in a
    // single frame. We do NOT cross-fade out — a fade would double up with
    // the title reveal beneath. The iris's inner img already matches the
    // hero's scale(1.16) translateY(-8%) baseline (see irisTransition.ts),
    // so the only thing that can cause a "background flash" is the hero
    // not being painted yet at removal time. waitForImagePainted is the
    // belt-and-braces check that prevents that:
    //   1. wait for load (bytes in)
    //   2. await decode() (decoded into memory, ready to paint)
    //   3. 2× requestAnimationFrame (compositor commits the paint)
    const irisOverlay = document.querySelector<HTMLElement>('.iris-overlay')
    if (irisOverlay) {
      const tripHero = document.querySelector<HTMLImageElement>('.trip-hero-img')
      const removeIris = () => irisOverlay.remove()

      const waitForImagePainted = async (img: HTMLImageElement) => {
        if (!img.complete || img.naturalWidth === 0) {
          await new Promise<void>(r => {
            img.addEventListener('load',  () => r(), { once: true })
            img.addEventListener('error', () => r(), { once: true })
          })
        }
        try { await img.decode() } catch {}
        await new Promise<void>(r => requestAnimationFrame(() => r()))
        await new Promise<void>(r => requestAnimationFrame(() => r()))
      }

      if (tripHero) {
        Promise.all([
          waitForImagePainted(tripHero),
          new Promise<void>(r => setTimeout(r, 300)),
        ]).then(removeIris)
      } else {
        setTimeout(() => requestAnimationFrame(() => irisOverlay.remove()), 250)
      }
    }

    // ── Hero ────────────────────────────────────────────────────────────
    const heroSection = document.querySelector<HTMLElement>('.hero')
    const heroImgWrap = document.getElementById('hero-img-wrap')
    if (heroSection && heroImgWrap) {
      const tl = gsap.timeline({ delay: 0.2 })
      tl.to('.hero-location', { opacity: 1, y: 0, duration: 0.9, ease: 'power3.out' })
        .to('.hero-title .line', { y: 0, duration: 1.3, stagger: 0.08, ease: 'power4.out' }, '-=0.5')
        .to('.hero-sub',         { opacity: 1, y: 0, duration: 1,   ease: 'power3.out' }, '-=0.7')

      // Parallax only when no scrub video (video scrub drives its own position)
      const heroVideo = document.getElementById('hero-video') as HTMLVideoElement | null
      if (!heroVideo) {
        gsap.to(heroImgWrap, {
          yPercent: 20, ease: 'none',
          scrollTrigger: {
            trigger: heroSection,
            start: 'top top',
            end:   'bottom top',
            scrub: 1,
          },
        })
      }

      // ── Hero video ──────────────────────────────────────────────────────
      // Desktop (≥769px): pin the hero and stretch the scrub over 200% of
      //   viewport-height of scroll — video stays in view ~2× longer.
      // Mobile  (≤768px):  pinning + frame scrubbing on touch feels stuck and
      //   chews battery, so just autoplay the same video as a smooth loop.
      // Reduced motion: skips both — the static poster image remains.
      // Tweak HERO_PIN_SCROLL to taste: '+=150%' ≈ 1.5×, '+=250%' ≈ 2.5×.
      if (heroVideo && !reduceMotion()) {
        const HERO_PIN_SCROLL = '+=200%'

        // preload="none" means no network activity until we call load().
        // Kick it off as soon as the hero is visible — for a pinned hero
        // this always fires immediately, but IO keeps the logic correct for
        // any future layout changes and avoids a naked load() on pages that
        // don't have a hero video.
        let videoLoadStarted = false
        const startVideoLoad = () => {
          if (videoLoadStarted) return
          videoLoadStarted = true
          heroVideo.load()
        }
        const heroLoadIO = new IntersectionObserver(
          (entries) => { if (entries[0].isIntersecting) { startVideoLoad(); heroLoadIO.disconnect() } },
          // Positive bottom margin expands detection downward so the load
          // fires 200px before the section would enter the viewport.
          { rootMargin: '0px 0px 200px 0px' }
        )
        heroLoadIO.observe(heroSection)

        // Fade the video in once it can play (shared by both desktop and mobile)
        const showHeroVideo = () => { heroVideo.style.opacity = '1' }
        if (heroVideo.readyState >= 2) showHeroVideo()
        else heroVideo.addEventListener('canplay', showHeroVideo, { once: true })

        mmHero = gsap.matchMedia()

        mmHero.add('(min-width: 769px)', () => {
          heroVideo.pause()

          // If the video is already seeking, stacking another currentTime
          // assignment forces the decoder to abandon the in-flight decode and
          // start over — the main cause of scrub jitter on full-res video.
          // Instead, park the target time and apply it once the seek lands.
          let pendingSeekTime: number | null = null
          const onSeeked = () => {
            if (pendingSeekTime !== null) {
              heroVideo.currentTime = pendingSeekTime
              pendingSeekTime = null
            }
          }
          heroVideo.addEventListener('seeked', onSeeked)

          // readyState 3 (HAVE_FUTURE_DATA) = enough buffered to render next
          // frame instantly; guards against seeking into unbuffered territory.
          const scrub = (progress: number) => {
            if (!heroVideo.duration || heroVideo.readyState < 3) return
            const t = progress * heroVideo.duration
            if (heroVideo.seeking) { pendingSeekTime = t; return }
            pendingSeekTime = null
            heroVideo.currentTime = t
          }
          ScrollTrigger.create({
            trigger: heroSection,
            start: 'top top',
            end:   HERO_PIN_SCROLL,
            pin:   true,
            pinSpacing: true,
            // scrub: true = zero GSAP lag; Lenis already provides easing so
            // adding a numeric scrub value just stacks a second delay on top.
            scrub: true,
            onUpdate: self => scrub(self.progress),
          })
          return () => {
            heroVideo.pause()
            heroVideo.removeEventListener('seeked', onSeeked)
          }
        })

        mmHero.add('(max-width: 768px)', () => {
          // Ensure load() has been called (IO may not have fired yet on mobile
          // if the browser deferred intersection checks).
          startVideoLoad()
          // Wait for canplay so the first frame is decoded before play() —
          // avoids the one-frame black flash on slower mobile connections.
          const doPlay = () => heroVideo.play().catch(() => {})
          if (heroVideo.readyState >= 2) doPlay()
          else heroVideo.addEventListener('canplay', doPlay, { once: true })
          return () => {
            heroVideo.pause()
            heroVideo.currentTime = 0
          }
        })
      }
    }

    // ── Expedition gallery (horizontal scroll + iris) ────────────────────
    const expSection = document.querySelector<HTMLElement>('.expedition')
    const expTrack   = document.getElementById('expedition-track') as HTMLElement | null
    if (expSection && expTrack) {
      // Cards fade in (0 → 1) as the gallery section enters the viewport.
      // Fully opaque by the time the section's top crosses ~40% from the
      // viewport bottom (i.e. the user has scrolled it into the lower half).
      gsap.set('.exp-card, .exp-end-cap', { opacity: 0 })
      gsap.to('.exp-card, .exp-end-cap', {
        opacity: 1,
        ease: 'none',
        scrollTrigger: {
          trigger: expSection,
          start: 'top 95%',     // small offset before begin = less twitchy
          end:   'top 40%',     // opacity 1 when section top is ~60% from bottom — cards arrive, not appear
          scrub: 0.5,
        },
      })

      mm = gsap.matchMedia()

      mm.add('(min-width: 769px)', () => {
        const cards = gsap.utils.toArray<HTMLElement>('.exp-card')
        // Compute live so invalidateOnRefresh picks up the post-resize value.
        // A captured const would return the stale width after a browser resize.
        const getScroll = () => expTrack.scrollWidth - window.innerWidth

        const hScroll = gsap.to(expTrack, {
          x: () => -getScroll(),
          ease: 'none',
          scrollTrigger: {
            trigger: expSection,
            pin: true,
            scrub: 1.2,
            end: () => `+=${getScroll()}`,
            invalidateOnRefresh: true,
            anticipatePin: 1,
          },
        })

        cards.forEach((card) => {
          // Per-card image parallax
          gsap.to(card.querySelector('.exp-card-img-wrap'), {
            x: 40, ease: 'none',
            scrollTrigger: {
              trigger: card,
              containerAnimation: hScroll,
              start: 'left right',
              end:   'right left',
              scrub: 1,
            },
          })
          // Card text stagger-in
          gsap.to(card.querySelectorAll('.exp-card-num, .exp-card-title, .exp-card-meta'), {
            opacity: 1, y: 0, stagger: 0.08, duration: 0.7, ease: 'power3.out',
            scrollTrigger: {
              trigger: card,
              containerAnimation: hScroll,
              start: 'left 80%',
              toggleActions: 'play none none reverse',
            },
          })
        })

        // End-cap stagger-in
        const endCap = document.querySelector<HTMLElement>('.exp-end-cap')
        if (endCap) {
          gsap.to(endCap.querySelectorAll('.end-cap-rule, .end-cap-eyebrow, .end-cap-heading, .end-cap-arrow-wrap'), {
            opacity: 1, y: 0, stagger: 0.1, duration: 0.8, ease: 'power3.out',
            scrollTrigger: {
              trigger: endCap,
              containerAnimation: hScroll,
              start: 'left 85%',
              toggleActions: 'play none none reverse',
            },
          })
        }
      })

      // Mobile: reveal card text immediately (vertical layout)
      mm.add('(max-width: 768px)', () => {
        gsap.utils.toArray<HTMLElement>('.exp-card-num, .exp-card-title, .exp-card-meta')
          .forEach(el => gsap.set(el, { opacity: 1, y: 0 }))
      })

      // Iris transition on card click — video stops first, iris uses the static image
      document.querySelectorAll<HTMLElement>('.exp-card').forEach((card) => {
        const preloadCardHero = () => {
          const heroUrl = card.dataset.heroUrl
          if (heroUrl && !document.querySelector(`link[rel="preload"][href="${CSS.escape(heroUrl)}"]`)) {
            const link = document.createElement('link')
            link.rel  = 'preload'
            link.as   = 'image'
            link.href = heroUrl
            document.head.appendChild(link)
          }
        }
        card.addEventListener('mouseenter', preloadCardHero, { once: true })

        card.addEventListener('click', (e) => {
          e.preventDefault()
          // Pause any playing card video before iris expands
          card.querySelector<HTMLVideoElement>('.exp-card-video')?.pause()
          const src     = card.dataset.src     ?? ''
          const href    = card.dataset.href    ?? card.getAttribute('href') ?? '/'
          const heroSrc = card.dataset.heroUrl ?? ''
          const img     = card.querySelector<HTMLImageElement>('.exp-card-img-wrap img')
          if (!img || !src) { window.location.href = href; return }
          playIrisTransition({ src, rect: img.getBoundingClientRect(), href, heroSrc })
        })
      })
    }

    // ── Card-video hover preview (.exp-card-video) ────────────────────────
    // Runs on any page that has .exp-card-video elements — home gallery AND
    // the expeditions archive grid. Touch devices autoplay on visibility;
    // mouse devices play on hover. Reduced motion skips entirely.
    if (!reduceMotion()) {
      const cardVideos = document.querySelectorAll<HTMLVideoElement>('.exp-card-video')
      if (cardVideos.length) {
        if (isTouch()) {
          const io = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
              const vid = entry.target as HTMLVideoElement
              if (entry.isIntersecting) {
                if (!vid.src) vid.src = vid.dataset.src ?? ''
                vid.play().catch(() => {})
                vid.classList.add('is-playing')
              } else {
                vid.pause()
                vid.classList.remove('is-playing')
              }
            })
          }, { threshold: 0.5 })
          cardVideos.forEach(v => io.observe(v))
        } else {
          cardVideos.forEach(vid => {
            // Closest card wrapper covers every layout that uses .exp-card-video:
            // .exp-card (home gallery), .exp-grid-card (expeditions archive),
            // .trip-next-card (next-expedition CTA at the bottom of trip pages).
            const card = vid.closest<HTMLElement>('.exp-card, .exp-grid-card, .trip-next-card')
            if (!card) return
            card.addEventListener('mouseenter', () => {
              if (!vid.src) vid.src = vid.dataset.src ?? ''
              vid.play().catch(() => {})
              vid.classList.add('is-playing')
            })
            card.addEventListener('mouseleave', () => {
              vid.pause()
              vid.currentTime = 0
              vid.classList.remove('is-playing')
            })
          })
        }
      }
    }

    // ── Expedition archive grid stagger reveal (/expeditions) ────────────
    // One continuous timeline: header → filter bar → cards.
    const expGrid = document.getElementById('expeditions-grid')
    if (expGrid) {
      const tl = gsap.timeline({ delay: 0.25 })
      tl.to('.expeditions-eyebrow', { opacity: 1, y: 0, duration: 0.6, ease: 'power3.out' })
        .to('.expeditions-title',   { opacity: 1, y: 0, duration: 0.9, ease: 'power4.out' }, '-=0.35')
        .to('.expeditions-count',   { opacity: 1, y: 0, duration: 0.5, ease: 'power3.out' }, '-=0.5')
        .to('.expeditions-bar',     { opacity: 1, y: 0, duration: 0.6, ease: 'power3.out' }, '-=0.1')
        // Cards start 0.2s after the filter bar finishes
        .to('.exp-grid-card', {
            opacity: 1, y: 0,
            duration: 0.85, stagger: 0.05, ease: 'power3.out',
          }, '+=0.2')

      // Progress trail fades with the filter bar
      const expTrail = document.querySelector<HTMLElement>('.exp-progress-trail')
      if (expTrail) {
        gsap.to(expTrail, { opacity: 1, duration: 1, ease: 'power2.out', delay: 1.2 })
      }
    }

    // ── Gear page reveal (/gear) ──────────────────────────────────────────
    // One continuous timeline: header → filter bar → cards.
    if (document.querySelector('.gear-page')) {
      const gearGrid = document.getElementById('gear-grid')
      const gearTl = gsap.timeline({ delay: 0.25 })
      gearTl
        .to('.gear-eyebrow', { opacity: 1, y: 0, duration: 0.6, ease: 'power3.out' })
        .to('.gear-title',   { opacity: 1, y: 0, duration: 0.9, ease: 'power4.out' }, '-=0.35')
        .to('.gear-count',   { opacity: 1, y: 0, duration: 0.5, ease: 'power3.out' }, '-=0.5')
        .to('.gear-bar',     { opacity: 1, y: 0, duration: 0.6, ease: 'power3.out' }, '-=0.1')

      if (gearGrid) {
        gearTl.to('.gear-card', {
          opacity: 1, y: 0,
          duration: 0.65, stagger: 0.04, ease: 'power3.out',
        }, '+=0.2')
      }
    }

    // ── Featured sections (curated homepage trips) ────────────────────────
    // One data-driven block for every .feature section, regardless of layout.
    gsap.utils.toArray<HTMLElement>('.feature').forEach((section) => {
      const imgWrap = section.querySelector<HTMLElement>('.feature-img-wrap')
      if (imgWrap) {
        gsap.to(imgWrap, {
          yPercent: -10, ease: 'none',
          scrollTrigger: { trigger: section, start: 'top bottom', end: 'bottom top', scrub: 1 },
        })
      }
      const eyebrow = section.querySelector('.section-eyebrow')
      if (eyebrow) {
        gsap.to(eyebrow, {
          scrollTrigger: { trigger: section, start: 'top 75%', once: true },
          opacity: 1, y: 0, duration: 0.8, ease: 'power3.out',
        })
      }
      // .line is the clip mask; .line-inner is animated so long words never clip.
      gsap.to(section.querySelectorAll('.section-title .line-inner'), {
        scrollTrigger: { trigger: section, start: 'top 70%', once: true },
        y: 0, stagger: 0.08, duration: 1.2, ease: 'power4.out',
      })
      gsap.to(section.querySelectorAll('.section-body, .feature-quote, .feature-link'), {
        scrollTrigger: { trigger: section, start: 'top 60%', once: true },
        opacity: 1, y: 0, stagger: 0.12, duration: 0.9, ease: 'power3.out',
      })

      // ── Featured section click transitions ──────────────────────────────
      // Image area (feature-img-col / feature-bg) → iris from the feature photo,
      // matching the expedition gallery card pattern.
      // Text link (feature-link) → curtain, consistent with nav-level transitions.
      const imgAnchor  = section.querySelector<HTMLAnchorElement>('.feature-img-col, .feature-bg')
      const textAnchor = section.querySelector<HTMLAnchorElement>('.feature-link')

      if (imgAnchor) {
        // Preload the destination's full-res hero on hover so the iris has a
        // head start — same pattern as the expedition gallery cards.
        imgAnchor.addEventListener('mouseenter', () => {
          const heroUrl = imgAnchor.dataset.heroUrl
          if (heroUrl && !document.querySelector(`link[rel="preload"][href="${CSS.escape(heroUrl)}"]`)) {
            const preload = document.createElement('link')
            preload.rel  = 'preload'
            preload.as   = 'image'
            preload.href = heroUrl
            document.head.appendChild(preload)
          }
        }, { once: true })

        imgAnchor.addEventListener('click', (e) => {
          e.preventDefault()
          const href    = imgAnchor.getAttribute('href') ?? '/'
          const heroSrc = imgAnchor.dataset.heroUrl ?? ''
          const img     = imgAnchor.querySelector<HTMLImageElement>('.feature-img-wrap img')
          if (img?.src) {
            playIrisTransition({ src: img.src, rect: img.getBoundingClientRect(), href, heroSrc })
          } else {
            playCurtainTransition({ href })
          }
        })
      }

      if (textAnchor) {
        textAnchor.addEventListener('click', (e) => {
          e.preventDefault()
          playCurtainTransition({ href: textAnchor.getAttribute('href') ?? '/' })
        })
      }
    })

    // ── About section ────────────────────────────────────────────────────
    const aboutSection = document.querySelector<HTMLElement>('.about')
    if (aboutSection) {
      // Image parallax — same cadence as the feature sections
      const aboutImgWrap = aboutSection.querySelector<HTMLElement>('.about-img-wrap')
      if (aboutImgWrap) {
        gsap.to(aboutImgWrap, {
          yPercent: -8, ease: 'none',
          scrollTrigger: { trigger: aboutSection, start: 'top bottom', end: 'bottom top', scrub: 1 },
        })
      }

      // Text stagger reveal — eyebrow → headline lines → sub → body
      ScrollTrigger.create({
        trigger: aboutSection,
        start: 'top 68%',
        once: true,
        onEnter: () => {
          gsap.to('.about-eyebrow',              { opacity: 1, y: 0, duration: 0.8, ease: 'power3.out' })
          gsap.to('.about-headline .line-inner', { y: 0, stagger: 0.08, duration: 1.1, ease: 'power4.out', delay: 0.1 })
          gsap.to('.about-sub',                  { opacity: 1, y: 0, duration: 0.9, ease: 'power3.out', delay: 0.3 })
          gsap.to('.about-body',                 { opacity: 1, y: 0, duration: 0.9, ease: 'power3.out', delay: 0.45 })
          gsap.to('.about-img-badge',            { opacity: 1, y: 0, duration: 0.7, ease: 'power3.out', delay: 0.6 })
        },
      })

      // Detail strip stagger
      ScrollTrigger.create({
        trigger: '.about-details',
        start: 'top 88%',
        once: true,
        onEnter: () => {
          document.querySelectorAll<HTMLElement>('.about-detail-item').forEach((item, i) => {
            setTimeout(() => item.classList.add('is-visible'), i * 90)
          })
        },
      })
    }

    // ── Contact section ──────────────────────────────────────────────────
    const contactSection = document.querySelector<HTMLElement>('.contact')
    if (contactSection) {
      gsap.to('.contact-pre', {
        scrollTrigger: { trigger: '.contact', start: 'top 80%', once: true },
        opacity: 1, y: 0, duration: 0.8, ease: 'power3.out',
      })
      gsap.to('.contact-headline .line', {
        scrollTrigger: { trigger: '.contact-headline', start: 'top 85%', once: true },
        y: 0, stagger: 0.09, duration: 1.1, ease: 'power4.out',
      })
      gsap.to('.contact-sub, .contact-email-label, .contact-email, .contact-footer', {
        scrollTrigger: { trigger: '.contact-sub', start: 'top 85%', once: true },
        opacity: 1, y: 0, stagger: 0.12, duration: 0.8, ease: 'power3.out',
      })
    }

    // ── Trip page ─────────────────────────────────────────────────────────
    if (document.querySelector('.trip-page')) {
      fitTripTitles()
      document.fonts?.ready.then(fitTripTitles)

      // Hero parallax — image drifts as user scrolls through the hero
      const tripHeroImg = document.querySelector<HTMLElement>('.trip-hero-img')
      if (tripHeroImg && !reduceMotion()) {
        gsap.fromTo(tripHeroImg,
          { yPercent: -8, scale: 1.16 },
          {
            yPercent: 8,
            scale:    1.16,
            ease:     'none',
            scrollTrigger: {
              trigger: '.trip-hero',
              start:   'top top',
              end:     'bottom top',
              scrub:   1,
            },
          }
        )
      }

      // Reset text/hero states — exclude .trip-map-section which has its own
      // chained animation below (it starts visible so parallax measures correctly).
      gsap.set('.trip-title .line', { y: '110%' })
      gsap.set('.trip-stats-bar',   { opacity: 0, y: 20 })
      gsap.set('.back-btn',         { opacity: 0, x: -16 })
      gsap.set('.story-block:not(.trip-map-section)', { opacity: 0, y: 30 })
      // Override the CSS story-block transform so parallax has a clean origin
      gsap.set('.trip-map-section', { opacity: 0, y: 0 })

      // Stats stagger — each .stat ticks in after the bar appears
      const tl = gsap.timeline({ delay: 0.1 })
      tl.to('.trip-title .line', {
          y: 0, duration: 1.1, stagger: 0.07, ease: 'power4.out',
        })
        .to('.trip-stats-bar', {
          opacity: 1, y: 0, duration: 0.7, ease: 'power3.out',
        }, '-=0.7')
        .to('.back-btn', {
          opacity: 1, x: 0, duration: 0.6, ease: 'power3.out',
        }, '-=0.8')
        .call(() => {
          // Stagger .stat elements after bar is visible; CSS handles the transition
          document.querySelectorAll<HTMLElement>('.stat').forEach((s, i) => {
            setTimeout(() => {
              s.classList.add('is-visible')
              countUpStat(s)
            }, i * 60)
          })
        }, [], '-=0.3')

      // Generic story-block scroll reveal (excludes the map section)
      gsap.utils.toArray<HTMLElement>('.story-block:not(.trip-map-section)').forEach((block) => {
        gsap.to(block, {
          scrollTrigger: { trigger: block, start: 'top 82%' },
          opacity: 1, y: 0, duration: 0.9, ease: 'power3.out',
        })
      })

      // Field intel rows stagger in after the panel fades in
      const fieldIntel = document.querySelector<HTMLElement>('.trip-field-intel')
      if (fieldIntel) {
        ScrollTrigger.create({
          trigger: fieldIntel,
          start: 'top 75%',
          once: true,
          onEnter: () => {
            fieldIntel.querySelectorAll<HTMLElement>('.intel-row').forEach((row, i) => {
              setTimeout(() => row.classList.add('is-visible'), i * 70)
            })
          },
        })
      }

      // Conditions strip items stagger in
      const conditions = document.querySelector<HTMLElement>('.trip-conditions')
      if (conditions) {
        ScrollTrigger.create({
          trigger: conditions,
          start: 'top 80%',
          once: true,
          onEnter: () => {
            conditions.querySelectorAll<HTMLElement>('.condition-item').forEach((item, i) => {
              setTimeout(() => item.classList.add('is-visible'), i * 80)
            })
          },
        })
      }

      // Story-divider ✦ mark scales + rotates in — editorial flourish
      gsap.utils.toArray<HTMLElement>('.story-divider').forEach((d) => {
        const mark = d.querySelector('.story-divider-mark')
        if (!mark) return
        gsap.from(mark, {
          scale:    0.85,
          rotate:   -90,
          duration: 1.2,
          ease:     'power3.out',
          scrollTrigger: { trigger: d, start: 'top 85%', once: true },
        })
      })

      // Story images — fade in when the lazy load completes
      document.querySelectorAll<HTMLImageElement>(
        '.story-img img, .story-gallery-item img, .story-strip-item img'
      ).forEach(img => {
        const reveal = () => img.classList.add('is-loaded')
        if (img.complete && img.naturalWidth > 0) reveal()
        else img.addEventListener('load', reveal, { once: true })
      })

      // ── Route map: draw-on-enter → looping auto-track → desktop hover ──
      // Sequence: section fades in → route path draws → topo rings appear →
      // tracker dot rides the path in an infinite loop (mobile + desktop).
      // On desktop, moving the cursor over the map pauses the auto-loop and
      // hands control to the cursor scrubber; leaving resumes the loop.
      const mapSection = document.querySelector<HTMLElement>('.trip-map-section')
      if (mapSection) {
        gsap.to('.trip-map-svg', {
          yPercent: -6, ease: 'none',
          scrollTrigger: { trigger: mapSection, start: 'top bottom', end: 'bottom top', scrub: 1 },
        })

        const routePath   = document.querySelector<SVGPathElement>('.map-route-path')
        const progressEl  = mapSection.querySelector<SVGPathElement>('.map-route-progress')
        const trackerDot  = mapSection.querySelector<SVGCircleElement>('.map-tracker-dot')
        const trackerHalo = mapSection.querySelector<SVGCircleElement>('.map-tracker-halo')
        const mapWrap     = mapSection.querySelector<HTMLElement>('.trip-map-placeholder')
        const mapSvg      = mapSection.querySelector<SVGSVGElement>('.trip-map-svg')
        const rings       = gsap.utils.toArray<Element>('.map-topo-ring')
        if (rings.length) gsap.set(rings, { opacity: 0 })

        // Shared state — used by both auto-loop and hover scrubber
        let samples: Array<{ x: number; y: number; len: number }> = []
        let totalLen = 0

        const buildSamples = () => {
          if (!routePath) return false
          totalLen = routePath.getTotalLength()
          if (totalLen === 0) return false
          samples = []
          const N = 120
          for (let i = 0; i <= N; i++) {
            const len = (i / N) * totalLen
            const pt  = routePath.getPointAtLength(len)
            samples.push({ x: pt.x, y: pt.y, len })
          }
          return true
        }

        const findClosest = (mx: number, my: number) => {
          let best = samples[0]
          let bestDist = Infinity
          for (const s of samples) {
            const dx = s.x - mx, dy = s.y - my
            const d  = dx * dx + dy * dy
            if (d < bestDist) { bestDist = d; best = s }
          }
          return best
        }

        // ── Auto-looping tracker (runs on all devices after path draws) ──
        let autoTween: gsap.core.Tween | null = null
        let autoRunning = false

        const runAutoLoop = () => {
          if (!routePath || !progressEl || !trackerDot || !trackerHalo) return
          if (totalLen === 0) buildSamples()
          if (totalLen === 0) return

          // Kill any in-flight tweens cleanly
          if (autoTween) { autoTween.kill(); autoTween = null }
          gsap.killTweensOf([trackerDot, trackerHalo])

          autoRunning = true

          // Snap to path start, clear progress, then fade tracker in
          const startPt = routePath.getPointAtLength(0)
          trackerDot.setAttribute('cx',  startPt.x.toFixed(1))
          trackerDot.setAttribute('cy',  startPt.y.toFixed(1))
          trackerHalo.setAttribute('cx', startPt.x.toFixed(1))
          trackerHalo.setAttribute('cy', startPt.y.toFixed(1))
          if (progressEl) progressEl.style.strokeDasharray = '0 99999'

          gsap.to([trackerDot, trackerHalo], { opacity: 1, duration: 0.5, ease: 'power2.out' })

          const proxy = { t: 0 }
          autoTween = gsap.to(proxy, {
            t: 1,
            duration: 4.5,
            ease: 'power1.inOut',
            onUpdate() {
              if (!routePath || !progressEl) return
              const dist = proxy.t * totalLen
              const pt   = routePath.getPointAtLength(dist)
              progressEl.style.strokeDasharray = `${dist} ${totalLen - dist}`
              trackerDot.setAttribute('cx',  pt.x.toFixed(1))
              trackerDot.setAttribute('cy',  pt.y.toFixed(1))
              trackerHalo.setAttribute('cx', pt.x.toFixed(1))
              trackerHalo.setAttribute('cy', pt.y.toFixed(1))
            },
            onComplete() {
              // Fade out, then restart after a short pause
              gsap.killTweensOf([trackerDot, trackerHalo])
              gsap.to([trackerDot, trackerHalo], {
                opacity: 0, duration: 0.5, ease: 'power2.in',
                onComplete: () => { if (autoRunning) gsap.delayedCall(0.8, runAutoLoop) },
              })
            },
          })
        }

        // ── Scroll-triggered: fade → draw path → rings → start auto-loop ─
        ScrollTrigger.create({
          trigger: mapSection,
          start:   'top 90%',
          once:    true,
          onEnter: () => {
            gsap.to(mapSection, { opacity: 1, duration: 0.8, ease: 'power3.out' })

            if (routePath) {
              const pathLen = routePath.getTotalLength()
              if (pathLen > 0) {
                totalLen = pathLen  // seed early so auto-loop doesn't need to recompute
                routePath.style.strokeDasharray  = `${pathLen}`
                routePath.style.strokeDashoffset = `${pathLen}`
                gsap.to(routePath, {
                  strokeDashoffset: 0,
                  ease:     'power2.inOut',
                  duration: 2,
                  delay:    0.35,
                  onComplete: () => {
                    routePath.style.strokeDasharray  = ''
                    routePath.style.strokeDashoffset = ''
                    runAutoLoop()  // ← kick off the looping dot
                  },
                })
              }
            }

            if (rings.length) {
              gsap.to(rings, { opacity: 1, stagger: 0.12, duration: 0.8, ease: 'power2.out', delay: 0.4 })
            }
          },
        })

        // ── Desktop hover: pause auto-loop → cursor scrubber ────────────
        if (mapWrap && mapSvg && progressEl && routePath && trackerDot && trackerHalo && !isTouch()) {
          let svgPt: DOMPoint | null = null
          const toSvgCoords = (clientX: number, clientY: number) => {
            if (!svgPt) svgPt = mapSvg.createSVGPoint()
            svgPt.x = clientX; svgPt.y = clientY
            const ctm = mapSvg.getScreenCTM()
            if (!ctm) return { x: 0, y: 0 }
            const p = svgPt.matrixTransform(ctm.inverse())
            return { x: p.x, y: p.y }
          }

          let rafQueued = false
          let pendingX = 0, pendingY = 0

          const onMove = (e: MouseEvent) => {
            // First mousemove — pause the auto-loop
            if (autoTween?.isActive()) { autoTween.pause(); autoRunning = false }
            pendingX = e.clientX; pendingY = e.clientY
            if (rafQueued) return
            rafQueued = true
            requestAnimationFrame(() => {
              rafQueued = false
              if (samples.length === 0 && !buildSamples()) return
              const { x: sx, y: sy } = toSvgCoords(pendingX, pendingY)
              const hit = findClosest(sx, sy)
              progressEl.style.strokeDasharray = `${hit.len} ${totalLen - hit.len}`
              progressEl.classList.add('is-tracking')
              trackerDot.setAttribute('cx',  hit.x.toFixed(1))
              trackerDot.setAttribute('cy',  hit.y.toFixed(1))
              trackerHalo.setAttribute('cx', hit.x.toFixed(1))
              trackerHalo.setAttribute('cy', hit.y.toFixed(1))
              ;(trackerDot  as HTMLElement).style.opacity = '1'
              ;(trackerHalo as HTMLElement).style.opacity = '1'
            })
          }

          const onLeave = () => {
            progressEl.classList.remove('is-tracking')
            // Resume the loop from the beginning
            autoRunning = true
            runAutoLoop()
          }

          mapWrap.addEventListener('mousemove', onMove, { passive: true })
          mapWrap.addEventListener('mouseleave', onLeave)
        }
      }

      const nextCard = document.getElementById('next-trip-card')
      if (nextCard) {
        // Preload the destination's full-res hero on hover — gives the iris
        // animation (0.75s) a head start so the image is cached on arrival.
        nextCard.addEventListener('mouseenter', () => {
          const heroUrl = nextCard.dataset.heroUrl
          if (heroUrl && !document.querySelector(`link[rel="preload"][href="${CSS.escape(heroUrl)}"]`)) {
            const link = document.createElement('link')
            link.rel = 'preload'
            link.as  = 'image'
            link.href = heroUrl
            document.head.appendChild(link)
          }
        }, { once: true })

        nextCard.addEventListener('click', () => {
          // Pause the hover-preview video so iris uses the static image
          nextCard.querySelector<HTMLVideoElement>('.exp-card-video')?.pause()
          const src     = nextCard.dataset.src     ?? ''
          const href    = nextCard.dataset.href    ?? '/'
          const heroSrc = nextCard.dataset.heroUrl ?? ''
          const img     = nextCard.querySelector<HTMLImageElement>('.trip-next-img-wrap img')
          if (!img || !src) { window.location.href = href; return }
          playIrisTransition({ src, rect: img.getBoundingClientRect(), href, heroSrc })
        })
      }

      // ── TOC smooth-scroll with offset ───────────────────────────────────
      // Native anchor-link jumps bypass Lenis (which owns the scroll position)
      // AND drop the target flush against the viewport top, squishing the
      // section heading. We intercept clicks, then use Lenis (or a native
      // fallback) to glide to the target with breathing room above it.
      const TOC_OFFSET = 96  // px — keeps the heading clear of the nav
      document.querySelectorAll<HTMLAnchorElement>('.toc-item').forEach(link => {
        link.addEventListener('click', (e) => {
          const id = link.getAttribute('href')?.replace(/^#/, '')
          if (!id) return
          const target = document.getElementById(id)
          if (!target) return
          e.preventDefault()
          if (lenis) {
            lenis.scrollTo(target, { offset: -TOC_OFFSET, duration: 1.2 })
          } else {
            const top = target.getBoundingClientRect().top + window.scrollY - TOC_OFFSET
            window.scrollTo({ top, behavior: 'smooth' })
          }
          history.replaceState(null, '', `#${id}`)
        })
      })
    }

    // ── Elevation profile scroll driver ──────────────────────────────────
    const elevSidebar = document.querySelector<HTMLElement>('.elev-sidebar')
    const elevStrip   = document.querySelector<HTMLElement>('.elev-strip')
    if ((elevSidebar || elevStrip) && !reduceMotion()) {
      const elevDot     = document.getElementById('elev-dot')     as SVGCircleElement | null
      const elevReadout = document.getElementById('elev-readout') as SVGTextElement   | null
      const elevDotH    = document.getElementById('elev-dot-h')   as SVGCircleElement | null
      const rawPoints   = elevSidebar?.dataset.points
      const rawSvgPts   = elevSidebar?.dataset.svgPoints
      const rawStripPts = elevStrip?.dataset.stripPoints

      if (rawPoints && rawSvgPts) {
        const elPoints    = JSON.parse(rawPoints)  as number[]
        const svgPoints   = JSON.parse(rawSvgPts)  as { x: number; y: number }[]
        const stripPoints = rawStripPts ? JSON.parse(rawStripPts) as { x: number; y: number }[] : null
        const n           = elPoints.length

        const updateDot = () => {
          const progress = window.scrollY / Math.max(1, document.body.scrollHeight - window.innerHeight)
          const t        = Math.max(0, Math.min(1, progress)) * (n - 1)
          const lo       = Math.floor(t)
          const hi       = Math.min(lo + 1, n - 1)
          const frac     = t - lo

          const elev = elPoints[lo] + frac * (elPoints[hi] - elPoints[lo])

          // Vertical sidebar dot
          if (elevDot) {
            const cx = svgPoints[lo].x + frac * (svgPoints[hi].x - svgPoints[lo].x)
            const cy = svgPoints[lo].y + frac * (svgPoints[hi].y - svgPoints[lo].y)
            elevDot.setAttribute('cx', cx.toFixed(1))
            elevDot.setAttribute('cy', cy.toFixed(1))
            if (elevReadout) {
              elevReadout.setAttribute('x', (cx + 5).toFixed(1))
              elevReadout.setAttribute('y', cy.toFixed(1))
              elevReadout.textContent = `${Math.round(elev).toLocaleString()} ft`
            }
          }

          // Horizontal strip dot
          if (elevDotH && stripPoints) {
            const cx = stripPoints[lo].x + frac * (stripPoints[hi].x - stripPoints[lo].x)
            const cy = stripPoints[lo].y + frac * (stripPoints[hi].y - stripPoints[lo].y)
            elevDotH.setAttribute('cx', cx.toFixed(1))
            elevDotH.setAttribute('cy', cy.toFixed(1))
          }
        }

        window.addEventListener('scroll', updateDot, { passive: true })
        updateDot()
      }
    }

    // ── SVG #1 Horizon line draw (div scaleX — avoids SVG unit issues) ──
    document.querySelectorAll<HTMLElement>('.horizon-line').forEach(line => {
      const wrap = line.closest<HTMLElement>('.horizon-line-wrap')
      if (!wrap) return
      ScrollTrigger.create({
        trigger: wrap,
        start: 'top 95%',
        once: true,
        onEnter: () => {
          gsap.to(line, { scaleX: 1, duration: 1.8, ease: 'power2.inOut' })
        },
      })
    })

    // ── SVG #2 About topo rings ──────────────────────────────────────────
    const aboutTopo = document.querySelector<SVGSVGElement>('.about-topo')
    if (aboutTopo) {
      ScrollTrigger.create({
        trigger: '.about',
        start: 'top 68%',
        once: true,
        onEnter: () => {
          gsap.to(aboutTopo, { opacity: 1, duration: 2.5, ease: 'power2.out', delay: 0.2 })
        },
      })
    }

    // ── SVG #5 Compass needle (trip hero) ────────────────────────────────
    const compassNeedleN = document.querySelector<SVGPolygonElement>('.compass-needle-n')
    const compassEl      = document.querySelector<HTMLElement>('.trip-compass')
    if (compassEl && compassNeedleN) {
      gsap.to(compassEl, { opacity: 1, duration: 0.8, ease: 'power2.out', delay: 0.6 })
      // Needle spins in and settles on north
      gsap.from(compassNeedleN, { rotate: -340, duration: 2.2, ease: 'power4.out', delay: 0.7 })
    }

    // ── SVG #7 Signal rings (contact) ────────────────────────────────────
    const signalRings = document.querySelector<HTMLElement>('.signal-rings')
    if (signalRings) {
      ScrollTrigger.create({
        trigger: '.contact',
        start: 'top 80%',
        once: true,
        onEnter: () => {
          gsap.to(signalRings, { opacity: 1, duration: 1.5, ease: 'power2.out' })
        },
      })
    }

    // ── SVG #9 Altitude lines (featured sections) ────────────────────────
    document.querySelectorAll<SVGLineElement>('.altitude-line').forEach(line => {
      const wrap  = line.closest<HTMLElement>('.altitude-line-wrap')
      const label = wrap?.querySelector<HTMLElement>('.altitude-label')
      ScrollTrigger.create({
        trigger: line.closest<HTMLElement>('.feature') ?? wrap,
        start: 'top 60%',
        once: true,
        onEnter: () => {
          gsap.to(line,  { strokeDashoffset: 0, duration: 1.2, ease: 'power2.inOut' })
          if (label) gsap.to(label, { opacity: 1, duration: 0.8, ease: 'power2.out', delay: 0.9 })
        },
      })
    })

    // Final refresh so all triggers compute correct positions
    ScrollTrigger.refresh()

    // ── Curtain overlay handoff ──────────────────────────────────────────
    // Lifted AFTER ScrollTrigger.refresh() so pin spacers are already inserted
    // and no layout shift occurs mid-lift (which caused the "dark rectangle"
    // flicker on the home page hero).
    const curtain = document.querySelector<HTMLElement>('.curtain-overlay')
    if (curtain) {
      gsap.to(curtain, {
        y:        '-100%',
        duration: 0.55,
        delay:    0.05,
        ease:     'power3.inOut',
        onComplete: () => curtain.remove(),
      })
    }
  }

  // ── Boot ───────────────────────────────────────────────────────────────
  initLenis()
  initCursor()

  // Animations fire on every page load (covers both initial load + transitions)
  document.addEventListener('astro:page-load', initPageAnimations)

  // Curtain transition — fires when navigating TO the main nav destinations
  // (home, /expeditions, /gear, /#contact). Specific expedition pages use the
  // iris transition instead (their click handlers call e.preventDefault() first,
  // so e.defaultPrevented catches them before this delegate runs).
  // Same-page guard prevents the curtain firing when clicking a nav link
  // you're already on (e.g. logo click while on home, or Expeditions while
  // already browsing /expeditions).
  // Use capture:true so this fires BEFORE Astro's ClientRouter listener.
  // Astro's router uses a capturing click handler internally; if we register
  // as a bubbling listener, Astro's handler runs first and sets
  // e.defaultPrevented = true, which would suppress our curtain entirely.
  // Capturing gives us first crack — we prevent default for our paths and
  // call navigate() ourselves after the curtain animation completes.
  const CURTAIN_PATHS = new Set(['/', '', '/expeditions', '/expeditions/', '/gear', '/gear/', '/#contact'])
  document.addEventListener('click', (e) => {
    if (e.button !== 0 || e.metaKey || e.ctrlKey || e.shiftKey || e.altKey) return
    const a = (e.target as HTMLElement | null)?.closest?.('a') as HTMLAnchorElement | null
    if (!a) return
    const path = a.getAttribute('href') ?? ''
    if (!CURTAIN_PATHS.has(path)) return

    // Don't curtain if we're already on the destination page
    try {
      const dest = new URL(path || '/', window.location.href)
      if (dest.pathname === window.location.pathname) return
    } catch {}

    e.preventDefault()
    playCurtainTransition({ href: path || '/' })
  }, true)  // ← capture

  // Re-fit hero titles on resize (no-op on pages without a .trip-title)
  let fitRaf = 0
  window.addEventListener('resize', () => {
    cancelAnimationFrame(fitRaf)
    fitRaf = requestAnimationFrame(fitTripTitles)
  }, { passive: true })

  // ── Teardown + reinit between page swaps ──────────────────────────────
  // IMPORTANT: initLenis() must run BEFORE mm.revert() and ScrollTrigger.killAll()
  // so the scrollerProxy has a valid lenis reference when GSAP calls scrollTop()
  // during cleanup. Otherwise, lenis is null → proxy throws → initLenis() never runs.
  document.addEventListener('astro:after-swap', () => {
    if (lenisTicker) { gsap.ticker.remove(lenisTicker); lenisTicker = null }
    if (lenis)       { lenis.destroy(); lenis = null }
    initLenis()                                                    // ← re-create lenis first
    if (mm)          { mm.revert(); mm = null }                    // ← now proxy is valid
    if (mmHero)      { mmHero.revert(); mmHero = null }
    ScrollTrigger.killAll()                                        // ← now proxy is valid
    // Iris overlays are intentionally kept alive here — initPageAnimations
    // fades them out after the destination hero image has loaded, which
    // prevents the flash of unstyled background between navigation events.
  })
</script>
