---
import { ClientRouter } from 'astro:transitions'
import '../styles/global.css'
import Navigation from '../components/Navigation.astro'

interface Props {
  title?:        string
  description?:  string
  ogImage?:      string
  isExpedition?: boolean
  preloadImage?: string
}

const {
  title        = 'STRATA — A Field Journal',
  description  = 'Adventures written in stone, fire, ice and root. A field journal from the edges of the earth.',
  ogImage      = '/images/valley-fire.webp',
  isExpedition = false,
  preloadImage,
} = Astro.props
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title"       content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image"       content={ogImage} />
    <title>{title}</title>

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Preload the page's LCP hero image (passed per-page) for fastest paint -->
    {preloadImage && (
      <link rel="preload" as="image" href={preloadImage} fetchpriority="high" />
    )}

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Cormorant+Garamond:ital,wght@0,400;0,500;1,400&family=Space+Mono:wght@400;700&display=swap"
      rel="stylesheet"
    />

    <!-- Astro client-side router (View Transitions + astro:* events) -->
    <ClientRouter />
  </head>

  <body>
    <!-- Film-grain overlay -->
    <div class="grain" aria-hidden="true"></div>

    <!-- Custom cursor — transition:persist keeps these elements alive across
         page swaps so the RAF loop never needs to restart. -->
    <div class="cursor"      id="cursor"      transition:persist aria-hidden="true"></div>
    <div class="cursor-ring" id="cursor-ring" transition:persist aria-hidden="true"></div>

    <!-- Page content -->
    <div class="content" transition:animate="none">
      <Navigation isExpedition={isExpedition} />
      <slot />
    </div>
  </body>
</html>

<script>
  import Lenis from 'lenis'
  import { gsap } from 'gsap'
  import { ScrollTrigger } from 'gsap/ScrollTrigger'
  import { playIrisTransition } from '../utils/irisTransition'

  gsap.registerPlugin(ScrollTrigger)

  const isTouch = () => window.matchMedia('(hover: none) and (pointer: coarse)').matches

  // ── Trip title fit-to-width ────────────────────────────────────────────
  // The hero title is sized with a viewport-based clamp for maximum impact,
  // but a long word (e.g. "NARROWS") can exceed the available width and get
  // clipped by .trip-title { overflow: hidden }. Reset to the CSS size, then
  // shrink the font only if the widest line overflows — short words like
  // "FIRE" stay huge, long words scale down to fit. Runs after fonts load and
  // on resize so measurements use the actual display face (Bebas Neue).
  function fitTripTitles() {
    document.querySelectorAll<HTMLElement>('.trip-title').forEach((title) => {
      const lines = title.querySelectorAll<HTMLElement>('.line')
      if (!lines.length) return
      title.style.fontSize = ''                       // reset to the CSS clamp
      const avail = title.clientWidth
      if (!avail) return
      let widest = 0
      lines.forEach(l => { widest = Math.max(widest, l.scrollWidth) })
      if (widest > avail) {
        const base = parseFloat(getComputedStyle(title).fontSize)
        title.style.fontSize = `${base * (avail / widest) * 0.98}px`
      }
    })
  }

  // ── Module-level state ─────────────────────────────────────────────────
  let lenis:       InstanceType<typeof Lenis> | null = null
  let lenisTicker: ((time: number) => void)   | null = null
  let mm:          ReturnType<typeof gsap.matchMedia> | null = null

  // ── Lenis smooth scroll ────────────────────────────────────────────────
  function initLenis() {
    if (isTouch()) return

    lenis = new Lenis({
      duration:        1.4,
      easing:          (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
      wheelMultiplier: 1.0,
      touchMultiplier: 0,
      smoothWheel:     true,
      orientation:     'vertical',
    })

    lenis.on('scroll', () => ScrollTrigger.update())

    lenisTicker = (time: number) => lenis!.raf(time * 1000)
    gsap.ticker.add(lenisTicker)
    gsap.ticker.lagSmoothing(0)

    ScrollTrigger.scrollerProxy(document.documentElement, {
      scrollTop: (value?: number) => {
        // Guard: fall back to native scroll if lenis isn't ready yet
        if (!lenis) return document.documentElement.scrollTop || window.scrollY
        if (value !== undefined) lenis.scrollTo(value, { immediate: true })
        return lenis.scroll
      },
      getBoundingClientRect: () => ({
        top: 0, left: 0,
        width:  window.innerWidth,
        height: window.innerHeight,
      }),
    })

    ScrollTrigger.addEventListener('refresh', () => lenis?.resize())
    ScrollTrigger.refresh()
  }

  // ── Custom cursor ──────────────────────────────────────────────────────
  // Runs ONCE — cursor elements have transition:persist so the RAF loop
  // never stops and never needs to restart across page swaps.
  function initCursor() {
    if (isTouch()) return

    const cursor = document.getElementById('cursor')
    const ring   = document.getElementById('cursor-ring')
    if (!cursor || !ring) return

    let mx = window.innerWidth  / 2
    let my = window.innerHeight / 2
    let rx = mx, ry = my

    window.addEventListener('mousemove', (e: MouseEvent) => {
      mx = e.clientX
      my = e.clientY
    }, { passive: true })

    const tick = () => {
      rx += (mx - rx) * 0.12
      ry += (my - ry) * 0.12
      cursor.style.transform = `translate(${mx}px, ${my}px) translate(-50%, -50%)`
      ring.style.transform   = `translate(${rx}px, ${ry}px) translate(-50%, -50%)`
      requestAnimationFrame(tick)
    }
    requestAnimationFrame(tick)
  }

  // ── Page animations — called on every astro:page-load ─────────────────
  // All section-level scripts have been removed; this single function
  // owns every GSAP animation so it always runs regardless of which page
  // the user first lands on.
  function initPageAnimations() {

    // ── Iris overlay handoff ────────────────────────────────────────────
    // The overlay from the previous page's iris transition is kept on screen
    // until the destination hero is decoded, then removed in one frame. We do
    // NOT cross-fade it out: the overlay image and the hero are the same photo
    // at the same fullscreen framing, so a fade just layers a second "hero
    // fade-in" on top of the title reveal — which reads as the intro playing
    // twice. A hard cut after the hero has painted is seamless and prevents
    // the dark flash when the hero wasn't cached (e.g. from the expeditions grid).
    const irisOverlay = document.querySelector<HTMLElement>('.iris-overlay')
    if (irisOverlay) {
      const tripHero = document.querySelector<HTMLImageElement>('.trip-hero-img')
      // Two rAFs after decode: the first lets the browser commit the hero into
      // the frame, the second guarantees it has actually painted before we drop
      // the overlay — otherwise a single frame of the accent-colour background
      // behind the hero shows through (the short flash).
      const removeIris = () =>
        requestAnimationFrame(() => requestAnimationFrame(() => irisOverlay.remove()))
      if (tripHero) {
        // decode() resolves only when the image is fully decoded and ready to
        // paint — more reliable than .complete or the load event alone.
        tripHero.decode().catch(() => {}).then(removeIris)
      } else {
        irisOverlay.remove()
      }
    }

    // ── Hero ────────────────────────────────────────────────────────────
    const heroSection = document.querySelector<HTMLElement>('.hero')
    const heroImgWrap = document.getElementById('hero-img-wrap')
    if (heroSection && heroImgWrap) {
      const tl = gsap.timeline({ delay: 0.2 })
      tl.to('.hero-location', { opacity: 1, y: 0, duration: 0.9, ease: 'power3.out' })
        .to('.hero-title .line', { y: 0, duration: 1.3, stagger: 0.08, ease: 'power4.out' }, '-=0.5')
        .to('.hero-sub',         { opacity: 1, y: 0, duration: 1,   ease: 'power3.out' }, '-=0.7')

      gsap.to(heroImgWrap, {
        yPercent: 20, ease: 'none',
        scrollTrigger: {
          trigger: heroSection,
          start: 'top top',
          end:   'bottom top',
          scrub: 1,
        },
      })
    }

    // ── Expedition gallery (horizontal scroll + iris) ────────────────────
    const expSection = document.querySelector<HTMLElement>('.expedition')
    const expTrack   = document.getElementById('expedition-track') as HTMLElement | null
    if (expSection && expTrack) {
      mm = gsap.matchMedia()

      mm.add('(min-width: 769px)', () => {
        const cards       = gsap.utils.toArray<HTMLElement>('.exp-card')
        const totalScroll = expTrack.scrollWidth - window.innerWidth

        const hScroll = gsap.to(expTrack, {
          x: () => -totalScroll,
          ease: 'none',
          scrollTrigger: {
            trigger: expSection,
            pin: true,
            scrub: 1.2,
            end: () => `+=${totalScroll}`,
            invalidateOnRefresh: true,
            anticipatePin: 1,
          },
        })

        cards.forEach((card) => {
          // Per-card image parallax
          gsap.to(card.querySelector('.exp-card-img-wrap'), {
            x: 40, ease: 'none',
            scrollTrigger: {
              trigger: card,
              containerAnimation: hScroll,
              start: 'left right',
              end:   'right left',
              scrub: 1,
            },
          })
          // Card text stagger-in
          gsap.to(card.querySelectorAll('.exp-card-num, .exp-card-title, .exp-card-meta'), {
            opacity: 1, y: 0, stagger: 0.08, duration: 0.7, ease: 'power3.out',
            scrollTrigger: {
              trigger: card,
              containerAnimation: hScroll,
              start: 'left 80%',
              toggleActions: 'play none none reverse',
            },
          })
        })
      })

      // Mobile: reveal card text immediately (vertical layout)
      mm.add('(max-width: 768px)', () => {
        gsap.utils.toArray<HTMLElement>('.exp-card-num, .exp-card-title, .exp-card-meta')
          .forEach(el => gsap.set(el, { opacity: 1, y: 0 }))
      })

      // Iris transition on card click
      document.querySelectorAll<HTMLElement>('.exp-card').forEach((card) => {
        const preloadCardHero = () => {
          const heroUrl = card.dataset.heroUrl
          if (heroUrl && !document.querySelector(`link[rel="preload"][href="${CSS.escape(heroUrl)}"]`)) {
            const link = document.createElement('link')
            link.rel  = 'preload'
            link.as   = 'image'
            link.href = heroUrl
            document.head.appendChild(link)
          }
        }
        card.addEventListener('mouseenter', preloadCardHero, { once: true })

        card.addEventListener('click', (e) => {
          e.preventDefault()
          const src     = card.dataset.src     ?? ''
          const href    = card.dataset.href    ?? card.getAttribute('href') ?? '/'
          const heroSrc = card.dataset.heroUrl ?? ''
          const img     = card.querySelector<HTMLImageElement>('.exp-card-img-wrap img')
          if (!img || !src) { window.location.href = href; return }
          playIrisTransition({ src, rect: img.getBoundingClientRect(), href, heroSrc })
        })
      })
    }

    // ── Featured sections (curated homepage trips) ────────────────────────
    // One data-driven block for every .feature section, regardless of layout.
    gsap.utils.toArray<HTMLElement>('.feature').forEach((section) => {
      const imgWrap = section.querySelector<HTMLElement>('.feature-img-wrap')
      if (imgWrap) {
        gsap.to(imgWrap, {
          yPercent: -10, ease: 'none',
          scrollTrigger: { trigger: section, start: 'top bottom', end: 'bottom top', scrub: 1 },
        })
      }
      const eyebrow = section.querySelector('.section-eyebrow')
      if (eyebrow) {
        gsap.to(eyebrow, {
          scrollTrigger: { trigger: section, start: 'top 75%', once: true },
          opacity: 1, y: 0, duration: 0.8, ease: 'power3.out',
        })
      }
      // .line is the clip mask; .line-inner is animated so long words never clip.
      gsap.to(section.querySelectorAll('.section-title .line-inner'), {
        scrollTrigger: { trigger: section, start: 'top 70%', once: true },
        y: 0, stagger: 0.08, duration: 1.2, ease: 'power4.out',
      })
      gsap.to(section.querySelectorAll('.section-body, .feature-quote, .feature-link'), {
        scrollTrigger: { trigger: section, start: 'top 60%', once: true },
        opacity: 1, y: 0, stagger: 0.12, duration: 0.9, ease: 'power3.out',
      })
    })

    // ── Contact section ──────────────────────────────────────────────────
    const contactSection = document.querySelector<HTMLElement>('.contact')
    if (contactSection) {
      gsap.to('.contact-pre', {
        scrollTrigger: { trigger: '.contact', start: 'top 80%', once: true },
        opacity: 1, y: 0, duration: 0.8, ease: 'power3.out',
      })
      gsap.to('.contact-headline .line', {
        scrollTrigger: { trigger: '.contact-headline', start: 'top 85%', once: true },
        y: 0, stagger: 0.09, duration: 1.1, ease: 'power4.out',
      })
      gsap.to('.contact-email, .contact-footer', {
        scrollTrigger: { trigger: '.contact-email', start: 'top 85%', once: true },
        opacity: 1, y: 0, stagger: 0.15, duration: 0.8, ease: 'power3.out',
      })
    }

    // ── Trip page ─────────────────────────────────────────────────────────
    if (document.querySelector('.trip-page')) {
      // Scale the hero title to fit before the reveal animation, then again
      // once the display font has loaded (web-font metrics differ from fallback)
      fitTripTitles()
      document.fonts?.ready.then(fitTripTitles)

      // Reset text states — hero image shows immediately (no CSS hiding it)
      gsap.set('.trip-title .line', { y: '110%' })
      gsap.set('.trip-stats-bar',   { opacity: 0, y: 20 })
      gsap.set('.back-btn',         { opacity: 0, x: -16 })
      gsap.set('.story-block',      { opacity: 0, y: 30 })

      const tl = gsap.timeline({ delay: 0.1 })
      tl.to('.trip-title .line', {
          y: 0, duration: 1.1, stagger: 0.07, ease: 'power4.out',
        })
        .to('.trip-stats-bar', {
          opacity: 1, y: 0, duration: 0.7, ease: 'power3.out',
        }, '-=0.7')
        .to('.back-btn', {
          opacity: 1, x: 0, duration: 0.6, ease: 'power3.out',
        }, '-=0.8')

      gsap.utils.toArray<HTMLElement>('.story-block').forEach((block) => {
        gsap.to(block, {
          scrollTrigger: { trigger: block, start: 'top 82%' },
          opacity: 1, y: 0, duration: 0.9, ease: 'power3.out',
        })
      })

      const nextCard = document.getElementById('next-trip-card')
      if (nextCard) {
        // Preload the destination's full-res hero on hover — gives the iris
        // animation (0.75s) a head start so the image is cached on arrival.
        nextCard.addEventListener('mouseenter', () => {
          const heroUrl = nextCard.dataset.heroUrl
          if (heroUrl && !document.querySelector(`link[rel="preload"][href="${CSS.escape(heroUrl)}"]`)) {
            const link = document.createElement('link')
            link.rel = 'preload'
            link.as  = 'image'
            link.href = heroUrl
            document.head.appendChild(link)
          }
        }, { once: true })

        nextCard.addEventListener('click', () => {
          const src     = nextCard.dataset.src     ?? ''
          const href    = nextCard.dataset.href    ?? '/'
          const heroSrc = nextCard.dataset.heroUrl ?? ''
          const img     = nextCard.querySelector<HTMLImageElement>('img')
          if (!img || !src) { window.location.href = href; return }
          playIrisTransition({ src, rect: img.getBoundingClientRect(), href, heroSrc })
        })
      }
    }

    // Final refresh so all triggers compute correct positions
    ScrollTrigger.refresh()
  }

  // ── Boot ───────────────────────────────────────────────────────────────
  initLenis()
  initCursor()

  // Animations fire on every page load (covers both initial load + transitions)
  document.addEventListener('astro:page-load', initPageAnimations)

  // Re-fit hero titles on resize (no-op on pages without a .trip-title)
  let fitRaf = 0
  window.addEventListener('resize', () => {
    cancelAnimationFrame(fitRaf)
    fitRaf = requestAnimationFrame(fitTripTitles)
  }, { passive: true })

  // ── Teardown + reinit between page swaps ──────────────────────────────
  // IMPORTANT: initLenis() must run BEFORE mm.revert() and ScrollTrigger.killAll()
  // so the scrollerProxy has a valid lenis reference when GSAP calls scrollTop()
  // during cleanup. Otherwise, lenis is null → proxy throws → initLenis() never runs.
  document.addEventListener('astro:after-swap', () => {
    if (lenisTicker) { gsap.ticker.remove(lenisTicker); lenisTicker = null }
    if (lenis)       { lenis.destroy(); lenis = null }
    initLenis()                                                    // ← re-create lenis first
    if (mm)          { mm.revert(); mm = null }                    // ← now proxy is valid
    ScrollTrigger.killAll()                                        // ← now proxy is valid
    // Iris overlays are intentionally kept alive here — initPageAnimations
    // fades them out after the destination hero image has loaded, which
    // prevents the flash of unstyled background between navigation events.
  })
</script>
