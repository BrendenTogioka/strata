---
---

<section class="mountain-section" id="mountain">
  <div class="mtn-layer mtn-sky" id="mtn-sky">
    <img src="/images/mountains.webp" alt="Arctic mountain sunrise" loading="lazy" decoding="async" />
  </div>
  <div class="mtn-layer mtn-ground" id="mtn-ground">
    <img src="/images/mountains.webp" alt="" aria-hidden="true" loading="lazy" decoding="async" />
  </div>

  <div class="mtn-overlay"></div>

  <div class="mtn-content">
    <div class="mtn-text-block">
      <div class="section-eyebrow mtn-section-eyebrow" style="opacity:0;transform:translateY(12px)">
        <span class="eyebrow-num">004</span>
        <span class="eyebrow-line"></span>
        <span class="eyebrow-text">Alaska / Yukon</span>
      </div>

      <h2 class="section-title" aria-label="Arctic Dawn">
        <span class="line">ARCTIC</span>
        <span class="line arctic-accent">DAWN</span>
      </h2>

      <p class="section-body">
        Pink clouds streaked over <em>a frozen river valley</em>,
        the mountain range catching the first light before
        anything else — peaks igniting one by one
        as the temperature held well below zero.
      </p>
    </div>
  </div>
</section>

