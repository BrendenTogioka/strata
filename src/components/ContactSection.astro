---

<section class="contact" id="contact">

  <!-- Signal rings — concentric circles that pulse outward, JS fades in on scroll -->
  <div class="signal-rings" aria-hidden="true">
    <svg class="signal-svg" viewBox="0 0 300 300" xmlns="http://www.w3.org/2000/svg">
      <circle class="signal-ring" cx="150" cy="150" r="28"  fill="none" stroke="rgba(192,72,32,0.55)" stroke-width="1"/>
      <circle class="signal-ring" cx="150" cy="150" r="60"  fill="none" stroke="rgba(192,72,32,0.4)"  stroke-width="1"/>
      <circle class="signal-ring" cx="150" cy="150" r="96"  fill="none" stroke="rgba(192,72,32,0.28)" stroke-width="1"/>
      <circle class="signal-ring" cx="150" cy="150" r="136" fill="none" stroke="rgba(192,72,32,0.16)" stroke-width="1"/>
      <circle class="signal-ring" cx="150" cy="150" r="148" fill="none" stroke="rgba(192,72,32,0.08)" stroke-width="0.75"/>
    </svg>
  </div>

  <p class="contact-pre">Let's go somewhere</p>

  <h2 class="contact-headline" aria-label="Let's Go">
    <span class="line">LET'S</span>
    <span class="line">GO.</span>
  </h2>

  <p class="contact-sub">For collaboration, licensing, or to plan something extraordinary.</p>

  <p class="contact-email-label">Get in touch</p>
  <a class="contact-email" href="mailto:hello@ourroamingreels.com">
    hello@ourroamingreels.com
  </a>

  <div class="contact-footer">
    <span>© 2026 Our Roaming Reels</span>
    <nav class="contact-social" aria-label="Social media">
      <a href="https://www.instagram.com/ourroamingreels/" target="_blank" rel="noopener noreferrer">Instagram</a>
      <a href="https://www.youtube.com/@ourroamingreels" target="_blank" rel="noopener noreferrer">YouTube</a>
      <a href="https://www.tiktok.com/@ourroamingreels" target="_blank" rel="noopener noreferrer">TikTok</a>
    </nav>
    <span>All rights reserved</span>
  </div>
</section>
