<section class="narrows-section" id="narrows">
  <div class="narrows-bg" id="narrows-bg">
    <img src="/images/narrows.webp" alt="Zion Narrows" loading="lazy" decoding="async" />
  </div>

  <div class="narrows-overlay"></div>

  <div class="narrows-content">
    <div class="section-eyebrow" style="opacity:0;transform:translateY(12px)">
      <span class="eyebrow-num">002</span>
      <span class="eyebrow-line"></span>
      <span class="eyebrow-text">Zion, Utah</span>
    </div>

    <h2 class="section-title narrows-title" aria-label="The Narrows">
      <span class="line"><span class="line-inner">THE</span></span>
      <span class="line"><span class="line-inner canyon-accent">NARROWS</span></span>
    </h2>

    <p class="section-body">
      Knee-deep in the Virgin River, slot canyon walls
      closing to <em>six feet wide</em> overhead.
      The light never reaches the floor directly —
      it bounces off sandstone and arrives
      already ancient, already amber.
    </p>
  </div>
</section>

