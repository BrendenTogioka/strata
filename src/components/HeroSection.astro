---
interface Props {
  heroVideoUrl?: string
}
const { heroVideoUrl = '' } = Astro.props

// Source-quality delivery: no transformations — Cloudinary streams the exact
// MP4 you uploaded. Heaviest decode per seek; if scrub feels laggy again that's
// the trade-off, and we can reintroduce a cap (e.g. vc_h264,q_90,w_1920,fps_60)
// to dial back in stages.
// NOTE: only referenced by the (commented-out) <video> fallback below now.
const heroVideoMp4 = heroVideoUrl

// ── Canvas frame-sequence source ──────────────────────────────────────────
// The scroll-scrubbed hero is now an image frame sequence painted to <canvas>
// (see BaseLayout.astro hero block). Frames are extracted from the SAME
// Cloudinary video as the poster via start-offset transforms (so_<pct>p), so
// no separate upload is needed. We parse the cloud name / version / public-id
// out of heroVideoUrl and hand them to the canvas via data-* attributes.
//
// ⚑ FILL IN IF THE ASSET CHANGES: this regex assumes a standard delivery URL
//   …/res.cloudinary.com/<cloud>/video/upload/[transforms/]<vNNN>/<public/id>.<ext>
//   For the current asset it yields cloud=dlle6kl4n, version=v1779987514,
//   publicId=OurRoamingReels/hero-bg.
const heroCloud = heroVideoUrl.match(
  /\/res\.cloudinary\.com\/([^/]+)\/video\/upload\/(?:.*?\/)?(v\d+)\/(.+)\.[a-zA-Z0-9]+$/
)
const heroCloudName = heroCloud?.[1] ?? ''
const heroVersion   = heroCloud?.[2] ?? ''
const heroPublicId  = heroCloud?.[3] ?? ''
---

<section class="hero" id="hero">
  <div class:list={['hero-img-wrap', heroVideoUrl && 'hero-img-wrap--fill']} id="hero-img-wrap">
    <img
      src="https://res.cloudinary.com/dlle6kl4n/video/upload/so_0/v1779987514/OurRoamingReels/hero-bg.jpg"
      alt="Our Roaming Reels — a field journal from the edges of the earth"
      fetchpriority="high"
      loading="eager"
      decoding="sync"
    />
    {/* NOTE: the poster intentionally stays VISIBLE under the canvas — it's
        the same so_0 frame as canvas frame 1 and paints instantly (eager /
        high priority), so the hero is never blank while the first frame
        streams in. The canvas (.hero-canvas) fades in on top once ready.
        (The old <video> path hid this poster via `hero-img-hidden`; restore
        that class on the img if you ever revert to the commented video.) */}
    {heroVideoUrl && (
      <Fragment>
        {/*
          OLD — scroll-scrubbed <video>. Kept (commented) for the live A/B
          fallback test; do NOT delete until the canvas frame-sequence is
          verified on real desktop + mobile. See BaseLayout.astro hero block.

          <video
            id="hero-video"
            class="hero-video"
            muted
            playsinline
            preload="none"
            aria-hidden="true"
          >
            <source src={heroVideoMp4} type="video/mp4" />
          </video>
        */}

        {/* NEW — canvas frame-sequence target. Cloudinary parts parsed from
            heroVideoUrl are passed through for the scrub script to build
            per-frame URLs. If any part is empty the script bails and the
            static poster <img> above stays visible. */}
        <canvas
          id="hero-canvas"
          class="hero-canvas"
          aria-hidden="true"
          data-cloud={heroCloudName}
          data-version={heroVersion}
          data-public-id={heroPublicId}
        ></canvas>
      </Fragment>
    )}
  </div>

  <div class="hero-overlay"></div>

  <div class="hero-content">
    <div class="hero-location">
      <div class="hero-location-dot"></div>
      <span>No Fixed Location — Always Moving</span>
    </div>

    <h1 class="hero-title" aria-label="Our Roaming Reels">
      <span class="line">OUR ROAMING</span>
      <span class="line accent">REELS</span>
    </h1>

    <div class="hero-sub">
      <p class="hero-sub-text">
        Adventures written in stone, fire, ice and root.<br />
        A field journal from the edges of the earth.
      </p>
      <div class="hero-scroll-cue">
        <span>Descend</span>
        <div class="scroll-bar"></div>
      </div>
    </div>
  </div>
</section>

