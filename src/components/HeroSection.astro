---
interface Props {
  heroSequenceUrl?: string
}
const { heroSequenceUrl = '' } = Astro.props

// ── Canvas frame-sequence source ──────────────────────────────────────────
// The scroll-scrubbed hero is an image frame sequence painted to <canvas>
// (see BaseLayout.astro hero block). Frames are extracted from the Cloudinary
// video (heroSequenceUrl) via start-offset transforms (so_<pct>p) — no separate
// upload needed. We parse the cloud name / version / public-id out of
// heroSequenceUrl and hand them to the canvas via data-* attributes.
//
// ⚑ FILL IN IF THE ASSET CHANGES: this regex assumes a standard delivery URL
//   …/res.cloudinary.com/<cloud>/video/upload/[transforms/]<vNNN>/<public/id>.<ext>
//   For the current asset it yields cloud=dlle6kl4n, version=v1779987514,
//   publicId=OurRoamingReels/hero-bg.
const heroCloud = heroSequenceUrl.match(
  /\/res\.cloudinary\.com\/([^/]+)\/video\/upload\/(?:.*?\/)?(v\d+)\/(.+)\.[a-zA-Z0-9]+$/
)
const heroCloudName = heroCloud?.[1] ?? ''
const heroVersion   = heroCloud?.[2] ?? ''
const heroPublicId  = heroCloud?.[3] ?? ''
---

<!-- .hero is a tall scroll TRACK; .hero-sticky pins the visuals via CSS
     position:sticky (no GSAP pin — that broke scroll tracking on mobile). The
     scrub length is the .hero height in global.css, not a ScrollTrigger pin. -->
<section class="hero" id="hero">
  <div class="hero-sticky">
  <div class:list={['hero-img-wrap', heroSequenceUrl && 'hero-img-wrap--fill']} id="hero-img-wrap">
    <img
      src="https://res.cloudinary.com/dlle6kl4n/video/upload/so_0/v1779987514/OurRoamingReels/hero-bg.jpg"
      alt="Our Roaming Reels — a field journal from the edges of the earth"
      fetchpriority="high"
      loading="eager"
      decoding="sync"
    />
    {/* The poster stays VISIBLE under the canvas — it's the same so_0 frame as
        canvas frame 1 and paints instantly (eager / high priority), so the hero
        is never blank while the first frame streams in. The canvas fades in on
        top once ready (.is-ready). */}
    {/* Canvas frame-sequence target. Cloudinary parts parsed from heroSequenceUrl
        build the per-frame URLs; if any part is empty the script bails and the
        static poster <img> above stays visible. */}
    {heroSequenceUrl && (
      <canvas
        id="hero-canvas"
        class="hero-canvas"
        aria-hidden="true"
        data-cloud={heroCloudName}
        data-version={heroVersion}
        data-public-id={heroPublicId}
      ></canvas>
    )}
  </div>

  <div class="hero-overlay"></div>

  <div class="hero-content">
    <div class="hero-location">
      <div class="hero-location-dot"></div>
      <span>No Fixed Location — Always Moving</span>
    </div>

    <h1 class="hero-title" aria-label="Our Roaming Reels">
      <span class="line">OUR ROAMING</span>
      <span class="line accent">REELS</span>
    </h1>

    <div class="hero-sub">
      <p class="hero-sub-text">
        Adventures written in stone, fire, ice and root.<br />
        A field journal from the edges of the earth.
      </p>
      <div class="hero-scroll-cue">
        <span>Descend</span>
        <div class="scroll-bar"></div>
      </div>
    </div>
  </div>
  </div><!-- /.hero-sticky -->
</section>

