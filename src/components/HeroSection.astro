---
interface Props {
  heroVideoUrl?: string
}
const { heroVideoUrl = '' } = Astro.props

// Highest-quality delivery: mp4 served as the source upload (no re-encode);
// webm is a max-quality VP9 alternate for browsers that prefer it. Note: this
// trades scroll-scrub smoothness for fidelity — larger files + full framerate
// mean per-seek decode is heavier; jitter may return on slower hardware.
const heroVideoWebm = heroVideoUrl
  ? heroVideoUrl.replace('/upload/', '/upload/vc_vp9,q_100/').replace(/\.mp4$/, '.webm')
  : ''
const heroVideoMp4 = heroVideoUrl
---

<section class="hero" id="hero">
  <div class="hero-img-wrap" id="hero-img-wrap">
    <img
      src="https://res.cloudinary.com/dlle6kl4n/video/upload/so_0/v1779944356/strata/videos/Sequence_04_8_bw9d0z.jpg"
      alt="Strata — a field journal from the edges of the earth"
      fetchpriority="high"
      loading="eager"
      decoding="sync"
      class={heroVideoUrl ? 'hero-img-hidden' : ''}
    />
    {heroVideoUrl && (
      <video
        id="hero-video"
        class="hero-video"
        muted
        playsinline
        preload="auto"
        aria-hidden="true"
      >
        <source src={heroVideoWebm} type="video/webm" />
        <source src={heroVideoMp4}  type="video/mp4" />
      </video>
    )}
  </div>

  <div class="hero-overlay"></div>

  <div class="hero-content">
    <div class="hero-location">
      <div class="hero-location-dot"></div>
      <span>No Fixed Location — Always Moving</span>
    </div>

    <h1 class="hero-title" aria-label="Strata">
      <span class="line">STRA</span>
      <span class="line accent">TA</span>
    </h1>

    <div class="hero-sub">
      <p class="hero-sub-text">
        Adventures written in stone, fire, ice and root.<br />
        A field journal from the edges of the earth.
      </p>
      <div class="hero-scroll-cue">
        <span>Descend</span>
        <div class="scroll-bar"></div>
      </div>
    </div>
  </div>
</section>

