---
interface Props {
  heroVideoUrl?: string
}
const { heroVideoUrl = '' } = Astro.props

// H.264 for the fastest scrub seeks; q_auto:best is Cloudinary's "lowest
// compression that's visually indistinguishable from source" — close to the
// uploaded quality at a fraction of q_100's file size. w_1920 caps at full
// HD (only downscales if larger), keeping retina-sharp on most viewports.
const heroVideoMp4 = heroVideoUrl
  ? heroVideoUrl.replace('/upload/', '/upload/vc_h264,q_auto:best,c_limit,w_1920,fps_60/')
  : ''
---

<section class="hero" id="hero">
  <div class="hero-img-wrap" id="hero-img-wrap">
    <img
      src="https://res.cloudinary.com/dlle6kl4n/video/upload/so_0/v1779945286/strata/videos/Sequence_07_psmvmg.jpg"
      alt="Strata — a field journal from the edges of the earth"
      fetchpriority="high"
      loading="eager"
      decoding="sync"
      class={heroVideoUrl ? 'hero-img-hidden' : ''}
    />
    {heroVideoUrl && (
      <video
        id="hero-video"
        class="hero-video"
        muted
        playsinline
        preload="auto"
        aria-hidden="true"
      >
        <source src={heroVideoMp4} type="video/mp4" />
      </video>
    )}
  </div>

  <div class="hero-overlay"></div>

  <div class="hero-content">
    <div class="hero-location">
      <div class="hero-location-dot"></div>
      <span>No Fixed Location — Always Moving</span>
    </div>

    <h1 class="hero-title" aria-label="Strata">
      <span class="line">STRA</span>
      <span class="line accent">TA</span>
    </h1>

    <div class="hero-sub">
      <p class="hero-sub-text">
        Adventures written in stone, fire, ice and root.<br />
        A field journal from the edges of the earth.
      </p>
      <div class="hero-scroll-cue">
        <span>Descend</span>
        <div class="scroll-bar"></div>
      </div>
    </div>
  </div>
</section>

