---
const imgBase = 'https://cdn.sanity.io/images/hmilopzv/production/a5b2b14dc8de8d9d09da7e3424f19bd5f50d91bb-2063x3095.webp'

const imgUrl    = `${imgBase}?w=1600&q=88&fm=webp&fit=max`
const imgSrcset = [800, 1200, 1600, 2000]
  .map(w => `${imgBase}?w=${w}&q=88&fm=webp&fit=max ${w}w`)
  .join(', ')
---

<section class="about" id="about">

  <!-- Topo contour rings — positioned over the text column (right 45%).
       Lives at section level so it isn't clipped by the text column's flow. -->
  <svg class="about-topo" viewBox="0 0 400 400" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
    <ellipse class="about-topo-ring" cx="200" cy="200" rx="55"  ry="42"  fill="none" stroke="rgba(192,72,32,0.7)"  stroke-width="0.8"/>
    <ellipse class="about-topo-ring" cx="200" cy="200" rx="95"  ry="72"  fill="none" stroke="rgba(192,72,32,0.5)"  stroke-width="0.8"/>
    <ellipse class="about-topo-ring" cx="200" cy="200" rx="140" ry="107" fill="none" stroke="rgba(192,72,32,0.32)" stroke-width="0.8"/>
    <ellipse class="about-topo-ring" cx="200" cy="200" rx="190" ry="146" fill="none" stroke="rgba(192,72,32,0.18)" stroke-width="0.8"/>
    <ellipse class="about-topo-ring" cx="200" cy="200" rx="250" ry="195" fill="none" stroke="rgba(192,72,32,0.09)" stroke-width="0.8"/>
  </svg>

  <!-- Image column -->
  <div class="about-img-col">
    <div class="about-img-wrap">
      <img
        src={imgUrl}
        srcset={imgSrcset}
        sizes="(max-width: 900px) 100vw, 55vw"
        alt="Brenden and Demeris on the Fire Wave at Valley of Fire — Our Roaming Reels"
        loading="lazy"
        decoding="async"
      />
    </div>
    <div class="about-img-overlay"></div>
  </div>

  <!-- Text column -->
  <div class="about-text-col">
    <p class="about-eyebrow">The Humans Behind the Lens</p>

    <div class="about-headline-row">
      <h2 class="about-headline" aria-label="Brenden and Demeris">
        <span class="line"><span class="line-inner">BRENDEN <span class="about-amp">&amp;</span></span></span>
        <span class="line"><span class="line-inner">DEMERIS</span></span>
      </h2>
      <div class="about-loc-badge">
        <div class="about-badge-dot"></div>
        <span>Los Angeles, CA</span>
      </div>
    </div>

    <p class="about-sub">
      We just really love being outside.<br />
      The rest kind of figured itself out.
    </p>

    <div class="about-body">
      <p>From desert canyon walls to open water, we go wherever the light is worth chasing. This is our record of it.</p>
      <p>We backpack, dive, paddle, and photograph. We've hauled tripods up ridgelines we had no business climbing and dropped into underwater visibility so clear it doesn't feel real. Somewhere between the trailhead and the waterline, we figured out this was the life.</p>
      <p>Based in Los Angeles — with two dogs and a cat who deserve their own journal.</p>
    </div>

  </div>

  <!-- Detail strip -->
  <div class="about-details">
    <div class="about-detail-item">
      <span class="about-detail-label">Based</span>
      <span class="about-detail-value">Los Angeles, CA</span>
    </div>
    <div class="about-detail-item">
      <span class="about-detail-label">Pursuits</span>
      <span class="about-detail-value">Trail · Sea · Summit</span>
    </div>
    <div class="about-detail-item">
      <span class="about-detail-label">Shot on</span>
      <span class="about-detail-value">Fujifilm X-H2S</span>
    </div>
    <div class="about-detail-item">
      <span class="about-detail-label">Crew</span>
      <span class="about-detail-value">Brenden, Demeris + 3</span>
    </div>
  </div>

</section>
