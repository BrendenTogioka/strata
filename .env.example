# Sanity CMS
PUBLIC_SANITY_PROJECT_ID=your_project_id_here
PUBLIC_SANITY_DATASET=production

# Write-scoped token — used ONLY by the node scripts in scripts/ (seed,
# import, migrate). The site build reads the public dataset with no token.
SANITY_WRITE_TOKEN=

# Enables the Cloudinary media browser inside Sanity Studio (/studio)
SANITY_STUDIO_CLOUDINARY_CLOUD_NAME=
